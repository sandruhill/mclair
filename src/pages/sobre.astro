---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const WA = 'https://wa.me/5511988600372?text=Olá%20Mclair!%20Gostaria%20de%20falar%20com%20a%20equipe.';

const reader = createReader(process.cwd(), keystaticConfig);
const sobreData = await reader.singletons.sobre.read().catch(() => null);
const valores  = (sobreData?.valores  ?? []) as any[];
const equipe   = (sobreData?.equipe   ?? []) as any[];
const timeline = (sobreData?.timeline ?? []) as any[];
---

<Layout
  title="Sobre a Mclair — Agência de Marketing e Comunicação Estratégica desde 2017"
  description="Conheça a Mclair: história, propósito, valores e equipe da agência especialista em Comunicação Estratégica e Marketing de Autoridade. São Paulo, desde 2017."
>

<!-- HERO -->
<section class="page-hero">
  <div class="ph-photo-bg" aria-hidden="true">
    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1600&q=80&auto=format&fit=crop" alt="" class="ph-photo-img" />
    <div class="ph-photo-overlay"></div>
  </div>
  <div class="ph-bg" aria-hidden="true">
    <div class="ph-blob-1"></div>
  </div>
  <div class="container ph-inner">
    <p class="eyebrow" data-anim style="color:rgba(255,255,255,.5)">
      <span style="background:rgba(255,255,255,.2);width:24px;height:2px;display:inline-block"></span>
      Quem somos
    </p>
    <h1 class="ph-title" data-anim data-delay="1">
      Agência de Marketing Estratégico<br/>
      <em>com foco em resultados duradouros</em>
    </h1>
    <p class="ph-sub" data-anim data-delay="2">
      Mais que uma agência, somos parceiros na construção do seu legado. A Mclair conecta marcas e pessoas através de Comunicação Estratégica com propósito e foco em Marketing de Autoridade.
    </p>
    <div class="ph-stats stagger-children" data-delay="3">
      <div class="phs-item">
        <strong class="counter" data-target="8" data-suffix="+">0</strong>
        <span>Anos de mercado</span>
      </div>
      <div class="phs-sep"></div>
      <div class="phs-item">
        <strong class="counter" data-target="200" data-suffix="+">0</strong>
        <span>Clientes atendidos</span>
      </div>
      <div class="phs-sep"></div>
      <div class="phs-item">
        <strong class="counter" data-target="11600" data-suffix="+">0</strong>
        <span>Inserções na mídia</span>
      </div>
      <div class="phs-sep"></div>
      <div class="phs-item">
        <strong class="counter" data-target="1734" data-suffix="+">0</strong>
        <span>Publicações internacionais</span>
      </div>
    </div>
  </div>
</section>

<!-- PURPOSE -->
<section class="section purpose-section">
  <div class="container purpose-grid">
    <div data-anim="left">
      <p class="eyebrow">Nosso propósito</p>
      <h2 class="section-title" style="margin-top:14px">
        Construir legados através da<br/><span>Comunicação com Propósito</span>
      </h2>
      <p class="section-lead" style="margin-top:16px">
        Acreditamos em propósitos transformadores que geram engajamento e constroem relacionamentos. Nosso objetivo é traduzir o valor da sua marca em comunicação com propósito que fortalece sua reputação de marca e deixa um legado.
      </p>
      <p class="section-lead" style="margin-top:12px">
        Somos formados por especialistas em Marketing de Autoridade, Comunicação Estratégica, Marketing Digital Integrado, Assessoria de Imprensa e Branding Estratégico — prontos para entregar resultados em comunicação que realmente importam.
      </p>
      <div class="purpose-actions" style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap">
        <a href="/contato" class="btn-primary">Conheça Nossos Valores</a>
        <a href={WA} class="btn-outline" target="_blank" rel="noopener">Fale com a Equipe</a>
      </div>
    </div>
    <div class="purpose-pillars stagger-children" data-anim="right">
      <div class="pp-item">
        <span class="pp-icon">◈</span>
        <div>
          <h3>Comunicação Estratégica</h3>
          <p>Toda mensagem planejada com dados e propósito claro</p>
        </div>
      </div>
      <div class="pp-item">
        <span class="pp-icon pp-teal">◉</span>
        <div>
          <h3>Marketing de Autoridade</h3>
          <p>Construindo referências reconhecidas no mercado</p>
        </div>
      </div>
      <div class="pp-item">
        <span class="pp-icon pp-orange">◆</span>
        <div>
          <h3>Resultados Duradouros</h3>
          <p>Estratégias que perene, não apenas imediatas</p>
        </div>
      </div>
      <div class="pp-item">
        <span class="pp-icon">◇</span>
        <div>
          <h3>Transparência Total</h3>
          <p>KPIs claros, relatórios honestos, evolução contínua</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HISTÓRIA / TIMELINE -->
<section class="section historia-section">
  <div class="container">
    <div style="text-align:center;max-width:520px;margin:0 auto 64px">
      <p class="eyebrow" data-anim style="justify-content:center">Nossa história</p>
      <h2 class="section-title" data-anim data-delay="1" style="margin-top:14px">
        Paixão por Comunicação<br/>Estratégica <span>desde 2017</span>
      </h2>
    </div>
    <div class="timeline">
      {timeline.map((t,i) => (
        <div class="tl-item" data-anim data-delay={(i%3+1).toString()}>
          <div class="tl-year-wrap">
            <span class="tl-year">{t.year}</span>
            <div class="tl-dot"></div>
          </div>
          <div class="tl-card">
            <p class="tl-text">{t.ev}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- VALORES -->
<section class="section valores-section">
  <div class="container">
    <div class="section-header-center" data-anim>
      <p class="eyebrow" style="justify-content:center">Nossos valores</p>
      <h2 class="section-title" style="margin-top:14px">O que nos move todo dia</h2>
    </div>
    <div class="valores-grid stagger-children">
      {valores.map(v => (
        <div class="valor-card">
          <span class="vc-icon">{v.icon}</span>
          <h3 class="vc-title">{v.title}</h3>
          <p class="vc-desc">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- EQUIPE -->
<section class="section equipe-section">
  <div class="container">
    <div class="section-header-center" data-anim>
      <p class="eyebrow" style="justify-content:center">Nossa equipe</p>
      <h2 class="section-title" style="margin-top:14px">As pessoas por trás da <span>Mclair</span></h2>
    </div>
    <div class="equipe-grid stagger-children">
      {equipe.map((m,i) => (
        <div class="membro-card">
          <div class="mc-avatar" style={`background:${['var(--red)','var(--teal)','var(--orange)','var(--red)'][i]}`}>
            {m.initials}
          </div>
          <h3 class="mc-nome">{m.nome}</h3>
          <span class="mc-cargo">{m.cargo}</span>
          <p class="mc-bio">{m.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>

</Layout>

<style>
/* HERO */
.page-hero {
  background:var(--dark); min-height:80vh;
  display:flex; align-items:center;
  position:relative; overflow:hidden;
  padding-top:78px;
}
.ph-photo-bg { position:absolute; inset:0; z-index:0; }
.ph-photo-img { width:100%; height:100%; object-fit:cover; object-position:center 30%; }
.ph-photo-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(21,18,16,.88) 0%,rgba(21,18,16,.7) 100%); }
.ph-bg { position:absolute; inset:0; pointer-events:none; z-index:1; }
.ph-blob-1 {
  position:absolute; width:600px;height:600px;
  border-radius:50%; filter:blur(100px);
  right:-100px; top:-100px;
  background:radial-gradient(circle,rgba(200,16,46,.12) 0%,transparent 70%);
}
.ph-inner { padding-top:72px; padding-bottom:72px; max-width:860px; position:relative; z-index:2; }
.ph-title {
  font-size:clamp(2.4rem,5vw,4.4rem); font-weight:900;
  letter-spacing:-.03em; line-height:1.08; color:#fff; margin:18px 0 22px;
}
.ph-title em { font-weight:300; font-style:italic; color:rgba(255,255,255,.5); }
.ph-sub { font-size:1rem; font-weight:300; color:rgba(255,255,255,.45); line-height:1.85; max-width:600px; }
.ph-stats { display:flex; align-items:center; gap:36px; flex-wrap:wrap; margin-top:52px; }
.phs-item { text-align:left; }
.phs-item strong { display:block; font-size:clamp(1.8rem,3.5vw,2.8rem); font-weight:900; color:var(--red); line-height:1; }
.phs-item span { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:rgba(255,255,255,.3); display:block; margin-top:6px; }
.phs-sep { width:1px; height:48px; background:rgba(255,255,255,.08); }

/* PURPOSE */
.purpose-section { background:#fff; }
.purpose-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.purpose-pillars { display:flex; flex-direction:column; gap:0; }
.pp-item {
  display:flex; align-items:flex-start; gap:18px;
  padding:20px 0; border-bottom:1px solid var(--line);
}
.pp-item:first-child { border-top:1px solid var(--line); }
.pp-icon { font-size:1.2rem; color:var(--red); flex-shrink:0; margin-top:2px; }
.pp-teal { color:var(--teal); }
.pp-orange { color:var(--orange); }
.pp-item h3 { font-size:.92rem; font-weight:700; color:var(--ink); margin-bottom:4px; }
.pp-item p { font-size:.82rem; color:var(--ink-3); font-weight:300; line-height:1.6; }

/* TIMELINE */
.historia-section { background:var(--cream-2); }
.timeline { display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
.tl-item { padding:32px 28px; border-left:1px solid var(--line); }
.tl-item:first-child { border-left:none; }
.tl-year-wrap { display:flex; align-items:center; gap:12px; margin-bottom:16px; }
.tl-year { font-size:.72rem; font-weight:700; letter-spacing:.12em; color:var(--red); background:var(--red-soft); padding:.3rem .8rem; border-radius:99px; }
.tl-dot { width:6px; height:6px; border-radius:50%; background:var(--red); }
.tl-card { }
.tl-text { font-size:.88rem; color:var(--ink-2); line-height:1.75; font-weight:300; }

/* VALORES */
.valores-section { background:#fff; }
.section-header-center { text-align:center; max-width:520px; margin:0 auto 56px; }
.valores-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2px; }
.valor-card {
  padding:36px 28px; background:var(--cream); border:1px solid var(--line);
  transition:border-color .25s, box-shadow .25s, transform .2s;
}
.valor-card:hover { border-color:var(--red); box-shadow:var(--shadow-md); transform:translateY(-3px); }
.vc-icon { font-size:1.4rem; color:var(--red); display:block; margin-bottom:18px; }
.vc-title { font-size:.95rem; font-weight:700; color:var(--ink); margin-bottom:10px; }
.vc-desc { font-size:.84rem; color:var(--ink-3); line-height:1.8; font-weight:300; }

/* EQUIPE */
.equipe-section { background:var(--cream-2); }
.equipe-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
.membro-card {
  background:#fff; border:1px solid var(--line); border-radius:var(--r-lg);
  padding:32px 24px; text-align:center;
  display:flex; flex-direction:column; align-items:center;
  transition:box-shadow .25s, transform .2s, border-color .2s;
}
.membro-card:hover { box-shadow:var(--shadow-md); transform:translateY(-4px); border-color:var(--red); }
.mc-avatar {
  width:70px; height:70px; border-radius:50%; color:#fff;
  display:flex; align-items:center; justify-content:center;
  font-size:1.2rem; font-weight:700; margin-bottom:18px;
}
.mc-nome { font-size:.98rem; font-weight:700; color:var(--ink); margin-bottom:5px; }
.mc-cargo { font-size:.65rem; letter-spacing:.1em; text-transform:uppercase; color:var(--red); margin-bottom:14px; }
.mc-bio { font-size:.82rem; font-weight:300; color:var(--ink-3); line-height:1.75; }

/* RESPONSIVE */
@media (max-width:1024px) { .valores-grid { grid-template-columns:1fr 1fr; } .equipe-grid { grid-template-columns:1fr 1fr; } }
@media (max-width:900px) { .purpose-grid { grid-template-columns:1fr; gap:48px; } .timeline { grid-template-columns:1fr 1fr; } }
@media (max-width:640px) {
  .timeline { grid-template-columns:1fr; }
  .tl-item { border-left:none; border-top:1px solid var(--line); padding:24px 0; }
  .ph-stats { gap:20px; }
  .phs-sep { height:28px; }
  .valores-grid { grid-template-columns:1fr; }
  .equipe-grid { grid-template-columns:1fr; }
}
</style>
