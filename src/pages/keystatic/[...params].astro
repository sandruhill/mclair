---
export const prerender = false;
import KeystaticApp from '../../components/KeystaticApp.jsx';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mclair CMS</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ─── Mclair CMS Theme ───────────────────────────────────────────── */

    /* 1. Override accent: indigo → violet/roxo (#7c3aed) */
    :root {
      --kui-color-scale-indigo11: #3b0764;
      --kui-color-scale-indigo10: #5b21b6;
      --kui-color-scale-indigo9:  #7c3aed;
      --kui-color-scale-indigo8:  #a78bfa;
      --kui-color-scale-indigo7:  #c4b5fd;
      --kui-color-scale-indigo6:  #ddd6fe;
      --kui-color-scale-indigo5:  #ede9fe;
      --kui-color-scale-indigo4:  #f5f3ff;
      --kui-color-scale-indigo3:  #f9f7ff;
      --kui-color-scale-indigo2:  #fdfcff;
      --kui-color-scale-indigo1:  #fefeff;

      /* 2. Fundo suave lavanda ao invés de branco puro */
      --kui-color-scale-slate1: #f8f7ff;
      --kui-color-scale-slate2: #ffffff;

      /* 3. Raios de borda mais generosos */
      --kui-size-radius-small:   6px;
      --kui-size-radius-regular: 10px;
      --kui-size-radius-medium:  12px;
      --kui-size-radius-large:   16px;
      --kui-size-radius-xlarge:  20px;

      /* 4. Inter como fonte principal */
      --kui-typography-font-family-base:
        'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* 5. Corpo base */
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      font-family: var(--kui-typography-font-family-base);
      background: var(--kui-color-scale-slate1);
    }

    /* 6. Sombras suaves nos painéis/cards */
    [data-keystatic-editor="root"] {
      box-shadow: 0 1px 3px rgba(124,58,237,0.08), 0 4px 16px rgba(124,58,237,0.06);
      border-radius: var(--kui-size-radius-large);
    }

    /* 7. Barra lateral — gradiente leve no fundo */
    nav[aria-label], aside {
      background: linear-gradient(160deg, #faf8ff 0%, #f3eeff 100%) !important;
    }

    /* 8. Item de nav ativo — destaque roxo */
    [aria-current="page"] {
      background: var(--kui-color-scale-indigo4) !important;
      color: var(--kui-color-scale-indigo9) !important;
      font-weight: 600;
    }

    /* 9. Botões primários — roxo sólido */
    [data-prominence="high"] {
      background: var(--kui-color-scale-indigo9) !important;
      color: #fff !important;
    }
    [data-prominence="high"]:hover {
      background: var(--kui-color-scale-indigo10) !important;
    }

    /* 10. Inputs — borda suave com focus roxo */
    input:focus, textarea:focus, [role="textbox"]:focus {
      outline: 2px solid var(--kui-color-scale-indigo6) !important;
      outline-offset: 0 !important;
      border-color: var(--kui-color-scale-indigo8) !important;
    }

    /* 11. Scrollbar customizada */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb {
      background: var(--kui-color-scale-indigo6);
      border-radius: 99px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--kui-color-scale-indigo8);
    }

    /* 12. Tags de seleção / chips */
    [data-selection-mode] [aria-selected="true"] {
      background: var(--kui-color-scale-indigo4) !important;
      border-color: var(--kui-color-scale-indigo6) !important;
    }
  </style>
</head>
<body>
  <KeystaticApp client:only="react" />
</body>
</html>
