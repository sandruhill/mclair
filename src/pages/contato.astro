<script is:inline>
(function(){
  var form = document.getElementById('contact-form');
  if (!form) return;

  function setError(id, msg) {
    var el = document.getElementById(id);
    el.classList.add('field-error');
    var err = el.parentElement.querySelector('.err-msg');
    if (!err) {
      err = document.createElement('span');
      err.className = 'err-msg';
      el.parentElement.appendChild(err);
    }
    err.textContent = msg;
  }

  function clearError(id) {
    var el = document.getElementById(id);
    el.classList.remove('field-error');
    var err = el.parentElement.querySelector('.err-msg');
    if (err) err.textContent = '';
  }

  function isValidEmail(v) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
  }

  ['nome','email','msg'].forEach(function(id) {
    var el = document.getElementById(id);
    el.addEventListener('input', function() { clearError(id); });
    el.addEventListener('blur', function() {
      var v = el.value.trim();
      if (!v) {
        setError(id, id === 'nome' ? 'Informe seu nome.' : id === 'email' ? 'Informe seu e-mail.' : 'Escreva sua mensagem.');
      } else if (id === 'email' && !isValidEmail(v)) {
        setError('email', 'E-mail inválido.');
      }
    });
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var valid = true;

    var nomeVal = document.getElementById('nome').value.trim();
    var emailVal = document.getElementById('email').value.trim();
    var msgVal = document.getElementById('msg').value.trim();

    clearError('nome'); clearError('email'); clearError('msg');

    if (!nomeVal) { setError('nome', 'Informe seu nome completo.'); valid = false; }
    if (!emailVal) { setError('email', 'Informe seu e-mail.'); valid = false; }
    else if (!isValidEmail(emailVal)) { setError('email', 'E-mail inválido. Verifique e tente novamente.'); valid = false; }
    if (!msgVal) { setError('msg', 'Escreva sua mensagem antes de enviar.'); valid = false; }

    if (!valid) {
      var first = form.querySelector('.field-error');
      if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
      return;
    }

    var empresa = document.getElementById('empresa').value.trim();
    var tel = document.getElementById('tel').value.trim();
    var servicos = [];
    document.querySelectorAll('input[name="servico"]:checked').forEach(function(cb) { servicos.push(cb.value); });

    var text = 'Olá Mclair! Me chamo ' + nomeVal
      + (empresa ? ', da empresa ' + empresa : '')
      + '.\n\n*Serviços de interesse:* ' + (servicos.length ? servicos.join(', ') : 'a definir')
      + '\n\n*Mensagem:* ' + msgVal
      + (tel ? '\n\n*Telefone:* ' + tel : '');
    window.open('https://wa.me/5511988600372?text=' + encodeURIComponent(text), '_blank');
  });
})();
</script>

