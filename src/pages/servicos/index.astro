---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const WA = 'https://wa.me/5511988600372?text=Olá%20Mclair!%20Gostaria%20de%20solicitar%20uma%20proposta.';

const reader = createReader(process.cwd(), keystaticConfig);
const allServicos = await reader.collections.servicos.all().catch(() => []);
const services = (allServicos as any[])
  .sort((a, b) => (a.entry.num ?? '').localeCompare(b.entry.num ?? ''))
  .map(s => ({
    num:      s.entry.num ?? '',
    color:    s.entry.color || 'var(--red)',
    bg:       s.entry.bg || 'var(--red-soft)',
    slug:     s.slug,
    title:    s.entry.title.name,
    headline: s.entry.headline ?? '',
    desc:     s.entry.homeDesc || s.entry.intro || '',
    items:    (s.entry.items ?? []) as string[],
    cta:      s.entry.cta ?? '',
  }));
---

<Layout
  title="Serviços Mclair — Marketing de Autoridade, Comunicação Estratégica e Branding"
  description="Soluções Mclair: Marketing de Autoridade, Branding Estratégico, Assessoria de Imprensa, Marketing Digital Integrado e Consultoria em Comunicação. Encontre a solução ideal para sua marca."
>

<!-- HERO -->
<section class="page-hero">
  <div class="ph-photo-bg" aria-hidden="true">
    <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=1600&q=80&auto=format&fit=crop" alt="" class="ph-photo-img" />
    <div class="ph-photo-overlay"></div>
  </div>
  <div class="ph-bg" aria-hidden="true">
    <div class="ph-blob-1"></div>
    <div class="ph-blob-2"></div>
  </div>
  <div class="container ph-inner">
    <div class="ph-content">
      <p class="eyebrow" data-anim style="color:rgba(255,255,255,.5)">
        <span style="background:rgba(255,255,255,.2);width:24px;height:2px;display:inline-block"></span>
        Nossas soluções
      </p>
      <h1 class="ph-title" data-anim data-delay="1">
        Comunicação Estratégica<br/>e <span>Marketing de Autoridade</span>
      </h1>
      <p class="ph-sub" data-anim data-delay="2">
        Encontre a solução ideal para sua marca — do Marketing de Autoridade ao Growth Hacking, da Assessoria de Imprensa ao Branding Estratégico. Nossa consultoria personaliza a estratégia certa para você.
      </p>
      <div class="ph-actions" data-anim data-delay="3">
        <a href={WA} class="btn-white" target="_blank" rel="noopener">Solicitar Proposta</a>
        <a href="/cases" class="btn-ghost">Ver Cases de Autoridade</a>
      </div>
    </div>
    <div class="ph-grid-visual stagger-children" data-anim="right" data-delay="2">
      {services.slice(0,3).map(s => (
        <div class="phgv-item">
          <span class="phgv-num" style={`color:${s.color}`}>{s.num}</span>
          <span class="phgv-title">{s.title}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICES LIST -->
<div class="services-list">
  {services.map((s,i) => (
    <section class={`svc-block ${i % 2 !== 0 ? 'svc-block-alt' : ''}`}>
      <div class="container svc-inner">
        <div class="svc-meta" data-anim="left">
          <span class="sm-num" style={`color:${s.color}`}>{s.num}</span>
          <div class="sm-accent" style={`background:${s.color}`}></div>
        </div>
        <div class="svc-content" data-anim data-delay="1">
          <span class="sc-tag" style={`color:${s.color};background:${s.bg}`}>{s.title}</span>
          <h2 class="sc-headline">{s.headline}</h2>
          <p class="sc-desc">{s.desc}</p>
          <ul class="sc-items stagger-children">
            {s.items.map(item => (
              <li>
                <span class="sci-dot" style={`background:${s.color}`}></span>
                {item}
              </li>
            ))}
          </ul>
          <div class="sc-actions">
            <a href={WA} class="btn-primary sc-wa" target="_blank" rel="noopener" style={`background:${s.color}`}>
              {s.cta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={`/servicos/${s.slug}`} class="sc-ver">
              Ver serviço completo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  ))}
</div>

</Layout>

<style>
/* HERO */
.page-hero {
  background:var(--dark); padding-top:78px;
  position:relative; overflow:hidden;
}
.ph-photo-bg { position:absolute; inset:0; z-index:0; }
.ph-photo-img { width:100%; height:100%; object-fit:cover; object-position:center 25%; }
.ph-photo-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(21,18,16,.88) 0%,rgba(21,18,16,.7) 100%); }
.ph-bg { position:absolute; inset:0; pointer-events:none; z-index:1; }
.ph-blob-1 { position:absolute; width:500px;height:500px;border-radius:50%;filter:blur(100px); top:-100px;right:-50px; background:radial-gradient(circle,rgba(200,16,46,.12) 0%,transparent 70%); }
.ph-blob-2 { position:absolute; width:350px;height:350px;border-radius:50%;filter:blur(100px); bottom:-60px;left:-60px; background:radial-gradient(circle,rgba(27,138,118,.08) 0%,transparent 70%); }
.ph-inner {
  display:grid; grid-template-columns:1fr 300px; gap:60px; align-items:center;
  padding-top:72px; padding-bottom:72px;
  position:relative; z-index:2;
}
.ph-title {
  font-size:clamp(2.4rem,5vw,4.2rem); font-weight:900;
  letter-spacing:-.03em; line-height:1.08; color:#fff; margin:18px 0 22px;
}
.ph-title span { color:var(--red); }
.ph-sub { font-size:1rem; font-weight:300; color:rgba(255,255,255,.45); line-height:1.85; max-width:520px; margin-bottom:32px; }
.ph-actions { display:flex; gap:12px; flex-wrap:wrap; }
.btn-white {
  display:inline-flex; align-items:center; gap:8px;
  font-size:.78rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  background:#fff; color:var(--dark);
  padding:.88rem 1.8rem; border-radius:var(--r-sm);
  transition:background .2s, transform .15s;
}
.btn-white:hover { background:var(--cream-2); transform:translateY(-2px); }
.btn-ghost {
  display:inline-flex; align-items:center;
  font-size:.78rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  color:rgba(255,255,255,.6); border:1.5px solid rgba(255,255,255,.2);
  padding:.85rem 1.7rem; border-radius:var(--r-sm);
  transition:border-color .2s, color .2s;
}
.btn-ghost:hover { border-color:rgba(255,255,255,.5); color:#fff; }

.ph-grid-visual { display:flex; flex-direction:column; gap:2px; }
.phgv-item {
  display:flex; align-items:center; gap:14px;
  padding:16px 18px;
  background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07);
  border-radius:var(--r-md);
}
.phgv-num { font-size:.65rem; font-weight:700; letter-spacing:.15em; flex-shrink:0; }
.phgv-title { font-size:.9rem; font-weight:700; color:rgba(255,255,255,.7); }

/* SERVICES */
.svc-block { padding:clamp(60px,8vw,100px) 0; background:#fff; border-bottom:1px solid var(--line); }
.svc-block-alt { background:var(--cream); }
.svc-inner { display:grid; grid-template-columns:120px 1fr; gap:60px; align-items:start; }
.svc-meta { padding-top:6px; }
.sm-num { font-size:6rem; font-weight:900; line-height:1; letter-spacing:-.05em; display:block; opacity:.08; }
.sm-accent { width:40px; height:3px; border-radius:99px; margin-top:12px; }

.sc-tag {
  display:inline-block; font-size:.65rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase;
  padding:.3rem .9rem; border-radius:99px; margin-bottom:14px;
}
.sc-headline { font-size:clamp(1.4rem,2.5vw,2rem); font-weight:700; color:var(--ink); margin-bottom:14px; line-height:1.2; }
.sc-desc { font-size:.95rem; color:var(--ink-3); line-height:1.85; font-weight:300; max-width:560px; margin-bottom:24px; }
.sc-items { display:grid; grid-template-columns:1fr 1fr; gap:10px 24px; }
.sc-items li { display:flex; align-items:flex-start; gap:10px; font-size:.85rem; color:var(--ink-3); line-height:1.5; }
.sci-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; margin-top:6px; }

.sc-actions { display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-top:28px; }
.sc-wa { white-space:nowrap; }
.sc-ver {
  display:inline-flex; align-items:center; gap:7px;
  font-size:.75rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
  color:var(--ink-3); border:1.5px solid var(--line-2);
  padding:.75rem 1.4rem; border-radius:var(--r-sm);
  white-space:nowrap;
  transition:border-color .2s, color .2s;
}
.sc-ver:hover { border-color:var(--ink-3); color:var(--ink); }

@media (max-width:900px) {
  .ph-inner { grid-template-columns:1fr; }
  .ph-grid-visual { display:none; }
  .svc-inner { grid-template-columns:1fr; gap:28px; }
  .sm-num { font-size:4rem; }
}
@media (max-width:600px) {
  .sc-items { grid-template-columns:1fr; }
  .sc-actions { flex-direction:column; align-items:flex-start; }
  .sc-wa, .sc-ver { width:100%; justify-content:center; }
}
</style>
