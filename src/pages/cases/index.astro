---
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const WA = 'https://wa.me/5511988600372?text=Olá%20Mclair!%20Quero%20saber%20mais%20sobre%20os%20cases.';

const reader = createReader(process.cwd(), keystaticConfig);
const allCases = await reader.collections.cases.all().catch(() => []);
const sorted = (allCases as any[])
  .sort((a, b) => (a.entry.num ?? '').localeCompare(b.entry.num ?? ''));

// First 6: full detailed cards; rest: compact cards
const cases = sorted.slice(0, 6).map(c => ({
  num:       c.entry.num ?? '',
  color:     c.entry.color || 'var(--red)',
  accent:    c.entry.accent || '#C8102E',
  slug:      c.slug,
  img:       c.entry.img ?? '',
  logo:      c.entry.logo ?? '',
  client:    c.entry.client.name,
  sector:    c.entry.sector ?? '',
  challenge: c.entry.challenge ?? '',
  solution:  c.entry.solution ?? '',
  results:   (c.entry.results ?? []) as { v: string; l: string }[],
  tags:      (c.entry.tags ?? []) as string[],
}));

const compactCases = sorted.slice(6).map(c => ({
  slug:   c.slug,
  accent: c.entry.accent || '#C8102E',
  client: c.entry.client.name,
  sector: c.entry.sector ?? '',
  result: c.entry.homeResult || (c.entry.results?.[0] ? `${c.entry.results[0].v} ${c.entry.results[0].l}` : ''),
  tags:   (c.entry.tags ?? []) as string[],
}));

const allCasesForSchema = sorted.map((c, i) => ({
  position: i + 1,
  name: `Case ${c.entry.client.name}`,
  url: `https://mclair.vercel.app/cases/${c.slug}`,
}));
---

<Layout
  title="Cases Mclair — Resultados Reais em Marketing de Autoridade e Comunicação Estratégica"
  description="Cases de sucesso da Mclair: Claudia Elisa, Fidalgo (+11.600 inserções), BMS/ABIMAQ (+1.734 internacionais), Alexandre Magno, Elemar Jr., Insight RH e mais. Resultados que falam por si."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Cases de Sucesso — Mclair Comunicação Estratégica',
    description: 'Resultados reais em Marketing de Autoridade, Assessoria de Imprensa e Comunicação Estratégica.',
    url: 'https://mclair.vercel.app/cases',
    itemListElement: allCasesForSchema.map((c: any) => ({ '@type': 'ListItem', ...c })),
  }}
>

<!-- HERO -->
<section class="page-hero">
  <div class="ph-photo-bg" aria-hidden="true">
    <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1600&q=80&auto=format&fit=crop" alt="" class="ph-photo-img" />
    <div class="ph-photo-overlay"></div>
  </div>
  <div class="ph-bg" aria-hidden="true">
    <div class="ph-blob-1"></div>
  </div>
  <div class="container ph-inner">
    <p class="eyebrow" data-anim style="color:rgba(255,255,255,.5)">
      <span style="background:rgba(255,255,255,.2);width:24px;height:2px;display:inline-block"></span>
      Resultados reais
    </p>
    <h1 class="ph-title" data-anim data-delay="1">
      Cases de Sucesso em<br/><span>Marketing de Autoridade</span><br/>e Comunicação Estratégica
    </h1>
    <p class="ph-sub" data-anim data-delay="2">
      Resultados falam mais alto. Navegue por nossos cases e veja como a Mclair ajudou marcas e profissionais a fortalecer sua reputação e alcançar objetivos reais.
    </p>
    <div class="ph-stats stagger-children" data-anim data-delay="3">
      <div class="phs-item">
        <strong class="counter" data-target="11600" data-suffix="+">0</strong>
        <span>Inserções na mídia</span>
      </div>
      <div class="phs-sep"></div>
      <div class="phs-item">
        <strong class="counter" data-target="1734" data-suffix="+">0</strong>
        <span>Publicações internacionais</span>
      </div>
      <div class="phs-sep"></div>
      <div class="phs-item">
        <strong>11</strong>
        <span>Cases em destaque</span>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED CASES (6) -->
<div class="cases-wrapper">
  {cases.map((c,i) => (
    <article class={`case-block ${i % 2 !== 0 ? 'case-block-alt' : ''}`}>
      <div class="container case-inner">
        <div class="case-intro" data-anim>
          <div class="ci-top">
            <span class="ci-num" style={`color:${c.color}`}>{c.num}</span>
            <span class="ci-sector tag" style={`color:${c.accent};border-color:${c.accent}30`}>{c.sector}</span>
          </div>
          {c.logo && (
            <div class="ci-logo-wrap">
              <img src={c.logo} alt={c.client} class="ci-logo" loading="lazy" />
            </div>
          )}
          <h2 class="ci-client">{c.client}</h2>
          <div class="ci-tags stagger-children">
            {c.tags.map(t => <span class="ci-tag">{t}</span>)}
          </div>
        </div>

        {c.img && (
          <div class="case-img-wrap" data-anim>
            <img src={c.img} alt={`Resultado Mclair — ${c.client}`} class="case-showcase-img" loading="lazy" />
            <div class="case-img-badge" style={`background:${c.accent}`}>Resultados do projeto</div>
          </div>
        )}

        <div class="case-body">
          <div class="cb-col" data-anim data-delay="1">
            <h3 class="cb-label">O Desafio</h3>
            <p class="cb-text">{c.challenge}</p>
          </div>
          <div class="cb-col" data-anim data-delay="2">
            <h3 class="cb-label">A Solução Mclair</h3>
            <p class="cb-text">{c.solution}</p>
          </div>
          <div class="cb-results" data-anim data-delay="3">
            <h3 class="cb-label">Resultados</h3>
            <div class="cbr-grid">
              {c.results.map(r => (
                <div class="cbr-item">
                  <strong style={`color:${c.accent}`}>{r.v}</strong>
                  <span>{r.l}</span>
                </div>
              ))}
            </div>
            <div class="cbr-actions">
              <a href={WA} class="btn-primary cbr-wa" target="_blank" rel="noopener" style={`background:${c.accent}`}>
                Quero Resultado Assim
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href={`/cases/${c.slug}`} class="cbr-ver">
                Ver case completo
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="case-accent-bar" style={`background:linear-gradient(90deg,${c.accent},transparent)`} data-anim="fade"></div>
    </article>
  ))}
</div>

<!-- COMPACT CASES (5) -->
<section class="section compact-section">
  <div class="container">
    <div style="text-align:center;max-width:560px;margin:0 auto 56px">
      <p class="eyebrow" data-anim style="justify-content:center">Mais cases de sucesso</p>
      <h2 class="section-title" data-anim data-delay="1" style="margin-top:14px">
        Outros projetos que <span>nos orgulham</span>
      </h2>
    </div>
    <div class="compact-grid">
      {compactCases.map((c, i) => (
        <a href={`/cases/${c.slug}`} class="compact-card" data-anim style={`--acc:${c.accent}`}>
          <div class="cc-head">
            <span class="cc-num" style={`color:${c.accent}`}>0{i+7}</span>
            <span class="cc-sector">{c.sector}</span>
          </div>
          <h3 class="cc-client">{c.client}</h3>
          <p class="cc-result">{c.result}</p>
          <div class="cc-tags">
            {c.tags.map(t => <span class="cc-tag">{t}</span>)}
          </div>
          <div class="cc-footer">
            <span class="cc-cta">
              Ver case completo
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </span>
          </div>
          <div class="cc-bar" style={`background:${c.accent}`}></div>
        </a>
      ))}
    </div>
  </div>
</section>

</Layout>

<style>
/* HERO */
.page-hero { background:var(--dark); padding-top:78px; position:relative; overflow:hidden; }
.ph-photo-bg { position:absolute; inset:0; z-index:0; }
.ph-photo-img { width:100%; height:100%; object-fit:cover; object-position:center 35%; }
.ph-photo-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(21,18,16,.9) 0%,rgba(21,18,16,.72) 100%); }
.ph-bg { position:absolute; inset:0; pointer-events:none; z-index:1; }
.ph-blob-1 { position:absolute; width:600px;height:600px;border-radius:50%;filter:blur(100px); top:-100px;right:-100px; background:radial-gradient(circle,rgba(200,16,46,.1) 0%,transparent 70%); }
.ph-inner { padding-top:72px; padding-bottom:72px; max-width:860px; position:relative; z-index:2; }
.ph-title { font-size:clamp(2.4rem,5vw,4.2rem); font-weight:900; letter-spacing:-.03em; line-height:1.08; color:#fff; margin:18px 0 22px; }
.ph-title span { color:var(--red); }
.ph-sub { font-size:1rem; font-weight:300; color:rgba(255,255,255,.45); line-height:1.85; max-width:580px; }
.ph-stats { display:flex; align-items:center; gap:36px; flex-wrap:wrap; margin-top:52px; }
.phs-item { text-align:left; }
.phs-item strong { display:block; font-size:clamp(1.8rem,3.5vw,2.8rem); font-weight:900; color:var(--red); line-height:1; }
.phs-item span { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:rgba(255,255,255,.3); display:block; margin-top:6px; }
.phs-sep { width:1px; height:48px; background:rgba(255,255,255,.08); }

/* FEATURED CASES */
.case-block { padding:clamp(64px,8vw,100px) 0; background:#fff; border-bottom:1px solid var(--line); position:relative; overflow:hidden; }
.case-block-alt { background:var(--cream); }
.case-intro { margin-bottom:48px; }
.ci-logo-wrap { margin-bottom:16px; }
.ci-logo { max-height:40px; max-width:160px; object-fit:contain; object-position:left; filter:grayscale(100%) opacity(.5); transition:filter .3s; }
.case-block:hover .ci-logo { filter:grayscale(0%) opacity(1); }
.ci-top { display:flex; align-items:center; gap:16px; margin-bottom:16px; }
.ci-num { font-size:.65rem; font-weight:700; letter-spacing:.18em; }
.ci-sector { font-size:.62rem; }
.ci-client { font-size:clamp(2rem,4vw,3.4rem); font-weight:900; color:var(--ink); letter-spacing:-.03em; line-height:1.05; }
.ci-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:16px; }
.ci-tag { font-size:.64rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-3); background:var(--cream-2); border:1px solid var(--line); padding:.25rem .7rem; border-radius:99px; }

.case-body { display:grid; grid-template-columns:1fr 1fr 300px; gap:40px; align-items:start; }
.cb-label { font-size:.65rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--ink-4); margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid var(--line); }
.cb-text { font-size:.92rem; color:var(--ink-3); line-height:1.85; font-weight:300; }

.cb-results { background:#fff; border:1px solid var(--line); border-radius:var(--r-lg); padding:24px; }
.case-block-alt .cb-results { background:var(--cream-2); }
.cbr-grid { display:flex; flex-direction:column; gap:0; margin-bottom:20px; }
.cbr-item { display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid var(--line); }
.cbr-item:last-child { border:none; }
.cbr-item strong { font-size:1.4rem; font-weight:900; line-height:1; }
.cbr-item span { font-size:.78rem; color:var(--ink-3); text-align:right; max-width:110px; line-height:1.4; }

/* Case image showcase */
.case-img-wrap {
  position:relative; margin-bottom:44px;
  border-radius:var(--r-lg); overflow:hidden;
  border:1px solid var(--line);
  box-shadow:0 8px 32px rgba(0,0,0,.07);
}
.case-showcase-img {
  width:100%; height:360px; object-fit:cover; object-position:top;
  display:block;
  transition:transform .5s cubic-bezier(.22,1,.36,1);
}
.case-img-wrap:hover .case-showcase-img { transform:scale(1.02); }
.case-img-badge {
  position:absolute; bottom:14px; left:14px;
  font-size:.6rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
  color:#fff; padding:.32rem .85rem; border-radius:99px;
  backdrop-filter:blur(4px);
}

.cbr-actions { display:flex; flex-direction:column; gap:10px; }
.cbr-wa {
  display:flex; align-items:center; justify-content:center; gap:7px;
  font-size:.65rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase;
  color:#fff; padding:.78rem 1rem; border-radius:var(--r-sm);
  white-space:nowrap; transition:opacity .2s, transform .15s;
}
.cbr-wa svg { flex-shrink:0; }
.cbr-wa:hover { opacity:.9; transform:translateY(-1px); }
.cbr-ver {
  display:flex; align-items:center; justify-content:center; gap:6px;
  font-size:.65rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase;
  color:var(--ink-3); border:1.5px solid var(--line-2);
  padding:.72rem 1rem; border-radius:var(--r-sm);
  white-space:nowrap; transition:border-color .2s, color .2s;
}
.cbr-ver:hover { border-color:var(--red); color:var(--red); }

.case-accent-bar { position:absolute; bottom:0; left:0; right:0; height:3px; opacity:.5; }

/* COMPACT CASES */
.compact-section { background:var(--cream-2); }
.compact-grid {
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:20px;
}
.compact-grid > .compact-card:nth-child(4),
.compact-grid > .compact-card:nth-child(5) {
  grid-column: span 1;
}
.compact-grid { grid-template-columns: repeat(3,1fr); }

.compact-card {
  background:#fff; border:1px solid var(--line); border-radius:var(--r-xl);
  padding:32px 28px; display:flex; flex-direction:column; gap:12px;
  position:relative; overflow:hidden;
  transition:border-color .25s, box-shadow .25s, transform .25s;
  text-decoration:none;
}
.compact-card:hover { border-color:var(--acc); box-shadow:var(--shadow-md); transform:translateY(-4px); }
.cc-head { display:flex; align-items:center; justify-content:space-between; }
.cc-num { font-size:.65rem; font-weight:700; letter-spacing:.18em; }
.cc-sector { font-size:.6rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-4); }
.cc-client { font-size:1.45rem; font-weight:900; color:var(--ink); letter-spacing:-.02em; line-height:1.1; }
.cc-result { font-size:.86rem; color:var(--ink-3); line-height:1.7; font-weight:300; flex:1; }
.cc-tags { display:flex; flex-wrap:wrap; gap:6px; }
.cc-tag { font-size:.6rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-4); background:var(--cream-2); border:1px solid var(--line); padding:.2rem .6rem; border-radius:99px; }
.cc-footer { margin-top:auto; padding-top:16px; border-top:1px solid var(--line); }
.cc-cta {
  display:inline-flex; align-items:center; gap:6px;
  font-size:.72rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
  color:var(--acc); transition:gap .2s;
}
.compact-card:hover .cc-cta { gap:10px; }
.cc-bar {
  position:absolute; bottom:0; left:0; right:0; height:3px;
  opacity:0; transition:opacity .25s;
}
.compact-card:hover .cc-bar { opacity:.7; }

@media (max-width:1100px) { .compact-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:900px) {
  .case-body { grid-template-columns:1fr; gap:28px; }
  .cb-results { max-width:400px; }
  .compact-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width:640px) {
  .ph-stats { gap:20px; }
  .phs-sep { height:28px; }
  .compact-grid { grid-template-columns:1fr; }
}
</style>
