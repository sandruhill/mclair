  height: 320px; overflow: hidden;
}
.cg-img {
  width: 100%; height: 100%; display: block;
  object-fit: cover; object-position: top center;
  transition: transform .6s cubic-bezier(.22,1,.36,1);
}
.cg-img-wrap:hover .cg-img { transform: scale(1.04); }
.cg-overlay {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-end;
  padding: 20px 24px;
  opacity: 0;
  transition: opacity .3s;
}
.cg-img-wrap:hover .cg-overlay { opacity: 1; }
.cg-caption {
  font-size: .78rem; font-weight: 500; color: #fff;
  line-height: 1.5; text-shadow: 0 1px 4px rgba(0,0,0,.4);
  margin-bottom: 8px;
}
.cg-zoom {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  color: #fff; background: rgba(255,255,255,.2); border-radius: 99px;
  padding: .3rem .85rem; backdrop-filter: blur(8px);
}

/* LIGHTBOX */
.cg-lightbox {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,.94);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity .25s;
}
.cg-lightbox.is-open { opacity: 1; pointer-events: all; }
.cg-lb-close {
  position: absolute; top: 20px; right: 24px;
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.12); border: none; border-radius: 50%;
  color: #fff; cursor: pointer;
  transition: background .2s; z-index: 2;
}
.cg-lb-close:hover { background: rgba(255,255,255,.25); }
.cg-lb-nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
  color: #fff; cursor: pointer; z-index: 2;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s, transform .2s;
}
.cg-lb-nav:hover { background: rgba(255,255,255,.22); }
.cg-lb-prev { left: 20px; }
.cg-lb-prev:hover { transform: translateY(-50%) translateX(-2px); }
.cg-lb-next { right: 20px; }
.cg-lb-next:hover { transform: translateY(-50%) translateX(2px); }
.cg-lb-nav:disabled { opacity: .25; pointer-events: none; }
.cg-lb-inner {
  display: flex; flex-direction: column; align-items: center;
  max-width: min(88vw, 1200px); max-height: 92vh;
  gap: 14px;
}
.cg-lb-img {
  max-width: 100%; max-height: 78vh;
  object-fit: contain; border-radius: var(--r-md);
  box-shadow: 0 24px 80px rgba(0,0,0,.6);
  transform: scale(.96);
  transition: transform .3s cubic-bezier(.22,1,.36,1), opacity .2s;
}
.cg-lightbox.is-open .cg-lb-img { transform: scale(1); }
.cg-lb-img.cg-fade { opacity: 0; transform: scale(.96); }
.cg-lb-caption {
  font-size: .82rem; color: rgba(255,255,255,.55); text-align: center;
  max-width: 680px; line-height: 1.6;
}
.cg-lb-dots {
  display: flex; gap: 8px; align-items: center;
}
.cg-lb-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(255,255,255,.25); border: none; cursor: pointer; padding: 0;
  transition: background .2s, transform .2s;
}
.cg-lb-dot.is-active { background: #fff; transform: scale(1.35); }

@media (max-width: 700px) {
  .cg-cols-2 { grid-template-columns: 1fr; }
}

/* OTHER CASES */
.other-cases { background: var(--cream-2); padding: clamp(52px,7vw,84px) 0; }
.oc-title { font-size: clamp(1.4rem,2.5vw,2rem); font-weight: 700; color: var(--ink); margin-bottom: 36px; }
.oc-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.oc-card {
  background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg);
  padding: 28px 24px; display: flex; flex-direction: column; gap: 8px;
  text-decoration: none; position: relative; overflow: hidden;
  transition: border-color .2s, box-shadow .2s, transform .2s;
}
.oc-card:hover { border-color: var(--red); box-shadow: var(--shadow-md); transform: translateY(-3px); }
.oc-num { font-size: .65rem; font-weight: 700; letter-spacing: .15em; }
.oc-client { font-size: 1rem; font-weight: 700; color: var(--ink); }
.oc-sector { font-size: .78rem; color: var(--ink-4); font-weight: 300; }
.oc-arrow { position: absolute; top: 20px; right: 20px; color: var(--ink-4); transition: color .2s, transform .2s; }
.oc-card:hover .oc-arrow { color: var(--red); transform: translate(2px,-2px); }

@media (max-width: 900px) { .cb-grid { grid-template-columns: 1fr; } .oc-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .oc-grid { grid-template-columns: 1fr; } .ch-num { display: none; } }
</style>

<script is:inline>
(function() {
  var lb      = document.getElementById('cg-lightbox');
  var lbImg   = document.getElementById('cg-lb-img');
  var lbCap   = document.getElementById('cg-lb-caption');
  var lbClose = document.getElementById('cg-lb-close');
  var lbPrev  = document.getElementById('cg-lb-prev');
  var lbNext  = document.getElementById('cg-lb-next');
  var lbDots  = document.getElementById('cg-lb-dots');
  if (!lb) return;

  var items = [];
  document.querySelectorAll('.cg-img-wrap').forEach(function(btn) {
    items.push({ src: btn.dataset.src, caption: btn.dataset.caption });
  });

  var cur = 0;

  // Build dots
  items.forEach(function(_, i) {
    var d = document.createElement('button');
    d.className = 'cg-lb-dot' + (i === 0 ? ' is-active' : '');
    d.setAttribute('aria-label', 'Imagem ' + (i + 1));
    d.addEventListener('click', function() { goTo(i); });
    lbDots.appendChild(d);
  });

  function syncDots() {
    lbDots.querySelectorAll('.cg-lb-dot').forEach(function(d, i) {
      d.classList.toggle('is-active', i === cur);
    });
    lbPrev.disabled = items.length <= 1;
    lbNext.disabled = items.length <= 1;
    if (items.length <= 1) { lbPrev.style.display = 'none'; lbNext.style.display = 'none'; lbDots.style.display = 'none'; }
  }

  function goTo(idx) {
    lbImg.classList.add('cg-fade');
    setTimeout(function() {
      cur = (idx + items.length) % items.length;
      lbImg.src = items[cur].src;
      lbImg.alt = items[cur].caption;
      lbCap.textContent = items[cur].caption;
      lbImg.onload = function() { lbImg.classList.remove('cg-fade'); };
      syncDots();
    }, 180);
  }

  function openLb(idx) {
    cur = idx;
    lbImg.src = items[cur].src;
    lbImg.alt = items[cur].caption;
    lbCap.textContent = items[cur].caption;
    lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    syncDots();
  }

  function closeLb() {
    lb.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.cg-img-wrap').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openLb(Number(btn.dataset.idx));
    });
  });

  lbPrev.addEventListener('click', function() { goTo(cur - 1); });
  lbNext.addEventListener('click', function() { goTo(cur + 1); });
  lbClose.addEventListener('click', closeLb);
  lb.addEventListener('click', function(e) {
    if (e.target === lb) closeLb();
  });
  document.addEventListener('keydown', function(e) {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape')     closeLb();
    if (e.key === 'ArrowLeft')  goTo(cur - 1);
    if (e.key === 'ArrowRight') goTo(cur + 1);
  });
})();
</script>
