/* GALLERY */
.case-gallery {
  background: var(--dark);
  padding: clamp(64px,8vw,100px) 0;
}
.cg-header { margin-bottom: 40px; }
.cg-label {
  display: inline-flex; align-items: center; gap: 8px;
