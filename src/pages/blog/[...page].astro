---
import Layout from '../../layouts/Layout.astro';
import posts from '../../data/blog.json';

export async function getStaticPaths({ paginate }) {
  return paginate(posts, { pageSize: 18 });
}

const { page } = Astro.props;
const BASE = 'https://mclair.vercel.app';

// ── Blog index JSON-LD ────────────────────────────────────────
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${BASE}/blog#blog`,
  name: 'Blog Mclair',
  description: 'Artigos sobre marketing, comunicação estratégica e branding da equipe Mclair.',
  url: `${BASE}/blog`,
  publisher: { '@id': `${BASE}/#organization` },
  inLanguage: 'pt-BR',
  blogPost: page.data.map(p => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `${BASE}/blog/${p.slug}`,
    ...(p.image && { image: p.image }),
    datePublished: p.date
      ? `${p.date.split('/')[2]}-${p.date.split('/')[1]}-${p.date.split('/')[0]}`
      : undefined,
    author: p.author
      ? { '@type': 'Person', name: p.author }
      : { '@id': `${BASE}/#organization` },
  })),
};

function stripHtml(html) {
  return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

function excerpt(html, len = 110) {
  const text = stripHtml(html);
  return text.length > len ? text.slice(0, len).trimEnd() + '…' : text;
}

function formatDate(d) {
  if (!d) return '';
  const [dd, mm, yy] = d.split('/');
  const months = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
  return `${parseInt(dd)} ${months[parseInt(mm)-1]} ${yy}`;
}
---

<Layout
  title={`Blog${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} — Mclair`}
  description="Artigos, insights e conteúdos sobre marketing, comunicação e branding da equipe Mclair."
  prevUrl={page.url.prev || undefined}
  nextUrl={page.url.next || undefined}
  schema={blogSchema}
>

<!-- HERO -->
<section class="blog-hero">
  <div class="bh-bg" aria-hidden="true">
    <div class="bh-blob bh-blob-1"></div>
    <div class="bh-blob bh-blob-2"></div>
    <div class="bh-grid"></div>
  </div>
  <div class="container bh-inner">
    <p class="eyebrow" data-anim style="justify-content:flex-start">
      <span class="he-line"></span>
      Conteúdo que gera autoridade
    </p>
    <h1 class="bh-title" data-anim data-delay="1">
      Blog <span>Mclair</span>
    </h1>
    <p class="bh-lead" data-anim data-delay="2">
      Insights, tendências e estratégias de marketing, comunicação e branding para quem quer se destacar.
    </p>
  </div>
</section>

<!-- POSTS GRID -->
<section class="section blog-section">
  <div class="container">

    {page.currentPage > 1 && (
      <p class="page-label">Página {page.currentPage}</p>
    )}

    <div class="blog-grid stagger-children">
      {page.data.map((post, i) => (
        <article class="blog-card" data-anim data-delay={((i % 3) + 1).toString()}>
          <a href={`/blog/${post.slug}`} class="bc-link">
            {post.image ? (
              <div class="bc-img-wrap">
                <img
                  src={post.image}
                  alt={post.title}
                  class="bc-img"
                  loading="lazy"
                  onerror="this.parentElement.style.display='none'"
                />
              </div>
            ) : (
              <div class="bc-img-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            )}
            <div class="bc-body">
              <div class="bc-meta">
                <time class="bc-date">{formatDate(post.date)}</time>
                {post.author && <span class="bc-dot">·</span>}
                {post.author && <span class="bc-author">{post.author}</span>}
              </div>
              <h2 class="bc-title">{post.title}</h2>
              {post.subtitle && <p class="bc-subtitle">{post.subtitle}</p>}
              <p class="bc-excerpt">{excerpt(post.content)}</p>
              <span class="bc-read">Ler artigo →</span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- PAGINATION -->
    <nav class="pagination" aria-label="Páginas do blog">
      {page.url.prev && (
        <a href={page.url.prev} class="pag-btn pag-prev">
          ← Anterior
        </a>
      )}
      <div class="pag-pages">
        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(n => (
          <a
            href={n === 1 ? '/blog' : `/blog/${n}`}
            class={`pag-num ${n === page.currentPage ? 'pag-active' : ''}`}
            aria-current={n === page.currentPage ? 'page' : undefined}
          >
            {n}
          </a>
        ))}
      </div>
      {page.url.next && (
        <a href={page.url.next} class="pag-btn pag-next">
          Próxima →
        </a>
      )}
    </nav>

  </div>
</section>

</Layout>

<style>
/* ═══ HERO ═══ */
.blog-hero {
  min-height: 44vh;
  background: var(--dark);
  position: relative; overflow: hidden;
  display: flex; align-items: center;
  padding-top: 88px;
}
.bh-bg { position:absolute;inset:0;pointer-events:none;z-index:0; }
.bh-blob {
  position:absolute; border-radius:50%; filter:blur(90px);
  animation:blob-float 12s ease-in-out infinite;
}
.bh-blob-1 { width:600px;height:600px;top:-200px;right:-100px;background:radial-gradient(circle,rgba(200,16,46,.14) 0%,transparent 70%); }
.bh-blob-2 { width:350px;height:350px;bottom:-80px;left:-60px;background:radial-gradient(circle,rgba(27,138,118,.1) 0%,transparent 70%);animation-delay:-6s; }
.bh-grid {
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(200,16,46,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,16,46,.04) 1px,transparent 1px);
  background-size:64px 64px;
}
@keyframes blob-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }

.bh-inner {
  position:relative; z-index:1;
  padding-top:72px; padding-bottom:72px;
}
.he-line { display:inline-block;width:32px;height:2px;background:var(--red);flex-shrink:0; }
.bh-title {
  font-size:clamp(3rem,7vw,6rem); font-weight:900; line-height:1.02;
  letter-spacing:-.04em; color:#fff; margin-top:16px; margin-bottom:18px;
}
.bh-title span { color:var(--red); }
.bh-lead { font-size:1rem;color:rgba(255,255,255,.45);line-height:1.8;max-width:520px;font-weight:300; }

/* ═══ BLOG SECTION ═══ */
.blog-section { background:#fff; padding-top:72px; padding-bottom:96px; }
.page-label {
  font-size:.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
  color:var(--ink-3); margin-bottom:40px;
}

/* ═══ GRID ═══ */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

/* ═══ CARD ═══ */
.blog-card {
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1.5px solid var(--line);
  background: #fff;
  transition: box-shadow .3s, transform .3s cubic-bezier(.22,1,.36,1), border-color .25s;
}
.blog-card:hover {
  box-shadow: 0 16px 48px rgba(0,0,0,.1);
  transform: translateY(-4px);
  border-color: rgba(200,16,46,.2);
}

.bc-link {
  display: flex; flex-direction: column;
  height: 100%;
  color: inherit; text-decoration: none;
}

.bc-img-wrap {
  width: 100%; height: 200px;
  overflow: hidden; flex-shrink: 0;
  background: var(--cream);
}
.bc-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  transition: transform .5s cubic-bezier(.22,1,.36,1);
}
.blog-card:hover .bc-img { transform: scale(1.04); }

.bc-img-placeholder {
  width: 100%; height: 200px;
  background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.bc-body {
  display: flex; flex-direction: column;
  padding: 24px 24px 28px;
  flex: 1;
}

.bc-meta {
  display: flex; align-items: center; gap: 6px;
  margin-bottom: 12px;
}
.bc-date {
  font-size: .65rem; font-weight: 700; letter-spacing:.1em;
  text-transform: uppercase; color: var(--ink-3);
}
.bc-dot { color: var(--ink-3); font-size: .65rem; }
.bc-author {
  font-size: .65rem; font-weight: 600; letter-spacing:.06em;
  text-transform: uppercase; color: var(--red);
}

.bc-title {
  font-size: 1.05rem; font-weight: 800; line-height: 1.3;
  letter-spacing: -.02em; color: var(--ink);
  margin-bottom: 8px;
}
.bc-subtitle {
  font-size: .82rem; font-weight: 600; color: var(--red);
  line-height: 1.4; margin-bottom: 8px;
}
.bc-excerpt {
  font-size: .82rem; color: var(--ink-3); line-height: 1.65;
  flex: 1; margin-bottom: 18px;
}
.bc-read {
  font-size: .7rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--red);
  transition: gap .2s;
}

/* ═══ PAGINATION ═══ */
.pagination {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  margin-top: 72px; flex-wrap: wrap;
}
.pag-btn {
  font-size: .75rem; font-weight: 700; letter-spacing: .08em;
  text-transform: uppercase; color: var(--ink);
  border: 1.5px solid var(--line); border-radius: var(--r-sm);
  padding: .65rem 1.4rem;
  transition: border-color .2s, color .2s, background .2s;
  text-decoration: none;
}
.pag-btn:hover { border-color: var(--red); color: var(--red); }
.pag-pages { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; }
.pag-num {
  display: inline-flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: var(--r-sm);
  font-size: .8rem; font-weight: 700;
  border: 1.5px solid var(--line); color: var(--ink);
  transition: border-color .2s, color .2s, background .2s;
  text-decoration: none;
}
.pag-num:hover { border-color: var(--red); color: var(--red); }
.pag-active {
  background: var(--red); color: #fff !important;
  border-color: var(--red) !important;
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 960px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}
@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; gap: 20px; }
}
</style>
