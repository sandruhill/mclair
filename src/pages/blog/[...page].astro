---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import legacyPosts from '../../data/blog.json';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import { documentToHtml } from '../../utils/documentToHtml';

// ── Merge CMS posts with legacy blog.json ────────────────────
let cmsPosts: any[] = [];
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  const all = await reader.collections.blog.all();
  cmsPosts = await Promise.all(
    all.map(async (p) => {
      const nodes = await p.entry.content();
      return {
        id: `cms-${p.slug}`,
        slug: p.slug,
        title: p.entry.title.name,
        subtitle: p.entry.subtitle ?? '',
        date: p.entry.date ?? '',
        author: p.entry.author ?? 'Equipe Mclair',
        image: (p.entry as any).featuredImage ?? p.entry.image ?? '',
        content: documentToHtml(nodes as any),
        category: (p.entry as any).category ?? 'geral',
        _cms: true,
      };
    })
  );
} catch {
  // No CMS posts yet
}

// Sort newest first — CMS date is YYYY-MM-DD, legacy is DD/MM/YYYY
function toTimestamp(d: string): number {
  if (!d) return 0;
  if (d.includes('-')) return new Date(d).getTime();
  const [dd, mm, yy] = d.split('/');
  return new Date(`${yy}-${mm}-${dd}`).getTime();
}

// Deduplicate: CMS takes priority over legacy (CMS has all migrated posts)
const cmsSlugsSet = new Set(cmsPosts.map((p: any) => p.slug));
const allPosts = [...cmsPosts, ...legacyPosts.filter((p: any) => !cmsSlugsSet.has(p.slug))].sort(
  (a, b) => toTimestamp(b.date) - toTimestamp(a.date)
);

export async function getStaticPaths({ paginate }) {
  // Re-run the same merge (getStaticPaths runs in its own scope)
  let cms: any[] = [];
  try {
    const { createReader } = await import('@keystatic/core/reader');
    const { default: cfg } = await import('../../../keystatic.config');
    const { documentToHtml: toHtml } = await import('../../utils/documentToHtml');
    const reader = createReader(process.cwd(), cfg);
    const all = await reader.collections.blog.all();
    cms = await Promise.all(
      all.map(async (p) => {
        const nodes = await p.entry.content();
        return {
          id: `cms-${p.slug}`,
          slug: p.slug,
          title: p.entry.title.name,
          subtitle: p.entry.subtitle ?? '',
          date: p.entry.date ?? '',
          author: p.entry.author ?? 'Equipe Mclair',
          image: (p.entry as any).featuredImage ?? p.entry.image ?? '',
          content: toHtml(nodes as any),
          category: (p.entry as any).category ?? 'geral',
          _cms: true,
        };
      })
    );
  } catch { /* no CMS posts */ }

  function ts(d: string) {
    if (!d) return 0;
    if (d.includes('-')) return new Date(d).getTime();
    const [dd, mm, yy] = d.split('/');
    return new Date(`${yy}-${mm}-${dd}`).getTime();
  }
  const { default: legacy } = await import('../../data/blog.json');
  const cmsSlugsDedup = new Set(cms.map((p: any) => p.slug));
  const merged = [...cms, ...legacy.filter((p: any) => !cmsSlugsDedup.has(p.slug))].sort((a, b) => ts(b.date) - ts(a.date));

  return paginate(merged, { pageSize: 18 });
}

const { page } = Astro.props;
const BASE = 'https://mclair.vercel.app';

// ── Blog index JSON-LD ────────────────────────────────────────
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${BASE}/blog#blog`,
  name: 'Blog Mclair',
  description: 'Artigos sobre marketing, comunicação estratégica e branding da equipe Mclair.',
  url: `${BASE}/blog`,
  publisher: { '@id': `${BASE}/#organization` },
  inLanguage: 'pt-BR',
  blogPost: page.data.map((p: any) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `${BASE}/blog/${p.slug}`,
    ...(p.image && { image: p.image }),
    datePublished: p.date
      ? p.date.includes('-')
        ? p.date
        : `${p.date.split('/')[2]}-${p.date.split('/')[1]}-${p.date.split('/')[0]}`
      : undefined,
    author: p.author
      ? { '@type': 'Person', name: p.author }
      : { '@id': `${BASE}/#organization` },
  })),
};

function stripHtml(html: string) {
  return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

function excerpt(html: string, len = 110) {
  const text = stripHtml(html);
  return text.length > len ? text.slice(0, len).trimEnd() + '…' : text;
}

function formatDate(d: string) {
  if (!d) return '';
  let dd: string, mm: string, yy: string;
  if (d.includes('-')) {
    [yy, mm, dd] = d.split('-');
  } else {
    [dd, mm, yy] = d.split('/');
  }
  const months = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
  return `${parseInt(dd)} ${months[parseInt(mm)-1]} ${yy}`;
}
---

<Layout
  title={`Blog${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} — Mclair`}
  description="Artigos, insights e conteúdos sobre marketing, comunicação e branding da equipe Mclair."
  prevUrl={page.url.prev || undefined}
  nextUrl={page.url.next || undefined}
  schema={blogSchema}
>

<!-- HERO -->
<section class="blog-hero">
  <div class="bh-bg" aria-hidden="true">
    <div class="bh-blob bh-blob-1"></div>
    <div class="bh-blob bh-blob-2"></div>
    <div class="bh-grid"></div>
  </div>
  <div class="container bh-inner">
    <p class="eyebrow" data-anim style="justify-content:flex-start">
      Conteúdo que gera autoridade
    </p>
    <h1 class="bh-title" data-anim data-delay="1">
      Blog <span>Mclair</span>
    </h1>
    <p class="bh-lead" data-anim data-delay="2">
      Insights, tendências e estratégias de marketing, comunicação e branding para quem quer se destacar.
    </p>
  </div>
</section>

<!-- POSTS GRID -->
<section class="section blog-section">
  <div class="container">

    {page.currentPage > 1 && (
      <p class="page-label">Página {page.currentPage}</p>
    )}

    <div class="blog-grid stagger-children">
      {page.data.map((post: any, i: number) => (
        <article class="blog-card" data-anim data-delay={((i % 3) + 1).toString()}>
          <a href={`/blog/${post.slug}`} class="bc-link">
            {post.image ? (
              <div class="bc-img-wrap">
                <img src={post.image} alt={post.title} class="bc-img" loading="lazy" onerror="this.parentElement.style.display='none'" />
              </div>
            ) : (
              <div class="bc-img-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            )}
            <div class="bc-body">
              <div class="bc-meta">
                <time class="bc-date">{formatDate(post.date)}</time>
                {post.author && <span class="bc-dot">·</span>}
                {post.author && <span class="bc-author">{post.author}</span>}
              </div>
              <h2 class="bc-title">{post.title}</h2>
              {post.subtitle && <p class="bc-subtitle">{post.subtitle}</p>}
              <p class="bc-excerpt">{excerpt(post.content)}</p>
              <span class="bc-read">Ler artigo →</span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Mobile layout -->
    <div class="blog-mobile-layout">
      <!-- Post 0: featured full-width -->
      {page.data.length > 0 && (
        <article class="blog-card blog-card-featured">
          <a href={`/blog/${page.data[0].slug}`} class="bc-link">
            {page.data[0].image ? (
              <div class="bc-img-wrap">
                <img src={page.data[0].image} alt={page.data[0].title} class="bc-img" loading="eager" onerror="this.parentElement.style.display='none'" />
              </div>
            ) : (
              <div class="bc-img-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            )}
            <div class="bc-body">
              <div class="bc-meta">
                <time class="bc-date">{formatDate(page.data[0].date)}</time>
                {page.data[0].author && <span class="bc-dot">·</span>}
                {page.data[0].author && <span class="bc-author">{page.data[0].author}</span>}
              </div>
              <h2 class="bc-title">{page.data[0].title}</h2>
              {page.data[0].subtitle && <p class="bc-subtitle">{page.data[0].subtitle}</p>}
              <p class="bc-excerpt">{excerpt(page.data[0].content)}</p>
              <span class="bc-read">Ler artigo →</span>
            </div>
          </a>
        </article>
      )}

      <!-- Posts 1-9: 2-col swipe carousel -->
      {page.data.length > 1 && (
        <div class="blog-swipe-wrap">
          {page.data.slice(1, 10).map((post) => (
            <article class="blog-card blog-swipe-card">
              <a href={`/blog/${post.slug}`} class="bc-link">
                {post.image ? (
                  <div class="bc-img-wrap">
                    <img src={post.image} alt={post.title} class="bc-img" loading="lazy" onerror="this.parentElement.style.display='none'" />
                  </div>
                ) : (
                  <div class="bc-img-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  </div>
                )}
                <div class="bc-body">
                  <div class="bc-meta">
                    <time class="bc-date">{formatDate(post.date)}</time>
                  </div>
                  <h2 class="bc-title">{post.title}</h2>
                  <p class="bc-excerpt">{excerpt(post.content, 80)}</p>
                  <span class="bc-read">Ler →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}

      <!-- Posts 10+: hidden, shown on "Carregar mais" -->
      {page.data.length > 10 && (
        <div class="blog-more-wrap" id="blog-more-wrap" aria-hidden="true">
          {page.data.slice(10).map((post) => (
            <article class="blog-card">
              <a href={`/blog/${post.slug}`} class="bc-link">
                {post.image ? (
                  <div class="bc-img-wrap">
                    <img src={post.image} alt={post.title} class="bc-img" loading="lazy" onerror="this.parentElement.style.display='none'" />
                  </div>
                ) : (
                  <div class="bc-img-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  </div>
                )}
                <div class="bc-body">
                  <div class="bc-meta">
                    <time class="bc-date">{formatDate(post.date)}</time>
                  </div>
                  <h2 class="bc-title">{post.title}</h2>
                  <p class="bc-excerpt">{excerpt(post.content, 80)}</p>
                  <span class="bc-read">Ler →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}

      {page.data.length > 10 && (
        <button class="blog-load-btn" id="blog-load-btn">
          Carregar mais
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      )}
    </div>

    <!-- PAGINATION -->
    <nav class="pagination" aria-label="Páginas do blog">
      {page.url.prev && (
        <a href={page.url.prev} class="pag-btn pag-prev">
          ← Anterior
        </a>
      )}
      <div class="pag-pages">
        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(n => (
          <a
            href={n === 1 ? '/blog' : `/blog/${n}`}
            class={`pag-num ${n === page.currentPage ? 'pag-active' : ''}`}
            aria-current={n === page.currentPage ? 'page' : undefined}
          >
            {n}
          </a>
        ))}
      </div>
      {page.url.next && (
        <a href={page.url.next} class="pag-btn pag-next">
          Próxima →
        </a>
      )}
    </nav>

  </div>
</section>

</Layout>

<style>
/* ═══ HERO ═══ */
.blog-hero {
  min-height: 44vh;
  background: var(--dark);
  position: relative; overflow: hidden;
  display: flex; align-items: center;
  padding-top: 88px;
}
.bh-bg { position:absolute;inset:0;pointer-events:none;z-index:0; }
.bh-blob {
  position:absolute; border-radius:50%; filter:blur(90px);
  animation:blob-float 12s ease-in-out infinite;
}
.bh-blob-1 { width:600px;height:600px;top:-200px;right:-100px;background:radial-gradient(circle,rgba(200,16,46,.14) 0%,transparent 70%); }
.bh-blob-2 { width:350px;height:350px;bottom:-80px;left:-60px;background:radial-gradient(circle,rgba(27,138,118,.1) 0%,transparent 70%);animation-delay:-6s; }
.bh-grid {
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(200,16,46,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,16,46,.04) 1px,transparent 1px);
  background-size:64px 64px;
}
@keyframes blob-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }

.bh-inner {
  position:relative; z-index:1;
  padding-top:72px; padding-bottom:72px;
}
.bh-title {
  font-size:clamp(3rem,7vw,6rem); font-weight:900; line-height:1.02;
  letter-spacing:-.04em; color:#fff; margin-top:16px; margin-bottom:18px;
}
.bh-title span { color:var(--red); }
.bh-lead { font-size:1rem;color:rgba(255,255,255,.45);line-height:1.8;max-width:520px;font-weight:300; }

/* ═══ BLOG SECTION ═══ */
.blog-section { background:#fff; padding-top:72px; padding-bottom:96px; }
.page-label {
  font-size:.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
  color:var(--ink-3); margin-bottom:40px;
}

/* ═══ GRID ═══ */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.blog-mobile-layout { display: none; }

/* ═══ CARD ═══ */
.blog-card {
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1.5px solid var(--line);
  background: #fff;
  transition: box-shadow .3s, transform .3s cubic-bezier(.22,1,.36,1), border-color .25s;
}
.blog-card:hover {
  box-shadow: 0 16px 48px rgba(0,0,0,.1);
  transform: translateY(-4px);
  border-color: rgba(200,16,46,.2);
}

.bc-link {
  display: flex; flex-direction: column;
  height: 100%;
  color: inherit; text-decoration: none;
}

.bc-img-wrap {
  width: 100%; height: 200px;
  overflow: hidden; flex-shrink: 0;
  background: var(--cream);
}
.bc-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  transition: transform .5s cubic-bezier(.22,1,.36,1);
}
.blog-card:hover .bc-img { transform: scale(1.04); }

.bc-img-placeholder {
  width: 100%; height: 200px;
  background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.bc-body {
  display: flex; flex-direction: column;
  padding: 24px 24px 28px;
  flex: 1;
}

.bc-meta {
  display: flex; align-items: center; gap: 6px;
  margin-bottom: 12px;
}
.bc-date {
  font-size: .65rem; font-weight: 700; letter-spacing:.1em;
  text-transform: uppercase; color: var(--ink-3);
}
.bc-dot { color: var(--ink-3); font-size: .65rem; }
.bc-author {
  font-size: .65rem; font-weight: 600; letter-spacing:.06em;
  text-transform: uppercase; color: var(--red);
}

.bc-title {
  font-size: 1.05rem; font-weight: 800; line-height: 1.3;
  letter-spacing: -.02em; color: var(--ink);
  margin-bottom: 8px;
}
.bc-subtitle {
  font-size: .82rem; font-weight: 600; color: var(--red);
  line-height: 1.4; margin-bottom: 8px;
}
.bc-excerpt {
  font-size: .82rem; color: var(--ink-3); line-height: 1.65;
  flex: 1; margin-bottom: 18px;
}
.bc-read {
  font-size: .7rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--red);
  transition: gap .2s;
}

/* ═══ PAGINATION ═══ */
.pagination {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  margin-top: 72px; flex-wrap: wrap;
}
.pag-btn {
  font-size: .75rem; font-weight: 700; letter-spacing: .08em;
  text-transform: uppercase; color: var(--ink);
  border: 1.5px solid var(--line); border-radius: var(--r-sm);
  padding: .65rem 1.4rem;
  transition: border-color .2s, color .2s, background .2s;
  text-decoration: none;
}
.pag-btn:hover { border-color: var(--red); color: var(--red); }
.pag-pages { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; }
.pag-num {
  display: inline-flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: var(--r-sm);
  font-size: .8rem; font-weight: 700;
  border: 1.5px solid var(--line); color: var(--ink);
  transition: border-color .2s, color .2s, background .2s;
  text-decoration: none;
}
.pag-num:hover { border-color: var(--red); color: var(--red); }
.pag-active {
  background: var(--red); color: #fff !important;
  border-color: var(--red) !important;
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 960px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}
@media (max-width: 600px) {
  .blog-grid-desktop { display: none; }
  .blog-mobile-layout { display: block; }

  /* Featured post */
  .blog-card-featured { margin-bottom: 16px; }

  /* Swipe carousel */
  .blog-swipe-wrap {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 12px;
    margin: 0 -20px;
    padding: 0 20px 16px;
  }
  .blog-swipe-wrap::-webkit-scrollbar { display: none; }
  .blog-swipe-card {
    flex: 0 0 calc(50% - 6px);
    min-width: 0;
    scroll-snap-align: start;
  }
  .blog-swipe-card .bc-img-wrap { height: 140px; }
  .blog-swipe-card .bc-img-placeholder { height: 140px; }
  .blog-swipe-card .bc-body { padding: 14px 14px 18px; }
  .blog-swipe-card .bc-title { font-size: .88rem; }

  /* More posts grid (hidden until loaded) */
  .blog-more-wrap {
    display: none;
  }
  .blog-more-wrap.loaded {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 12px;
  }
  .blog-more-wrap .bc-img-wrap { height: 140px; }
  .blog-more-wrap .bc-img-placeholder { height: 140px; }
  .blog-more-wrap .bc-body { padding: 14px 14px 18px; }
  .blog-more-wrap .bc-title { font-size: .88rem; }

  /* Load more button */
  .blog-load-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    margin-top: 20px;
    padding: .85rem 1.4rem;
    background: var(--cream-2);
    border: 1.5px solid var(--line-2);
    border-radius: var(--r-sm);
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink-2);
    cursor: pointer;
    transition: border-color .2s, color .2s, background .2s;
  }
  .blog-load-btn:hover { border-color: var(--red); color: var(--red); background: var(--red-soft); }
}
</style>

<script is:inline>
(function() {
  var btn = document.getElementById('blog-load-btn');
  var moreWrap = document.getElementById('blog-more-wrap');
  if (!btn || !moreWrap) return;
  btn.addEventListener('click', function() {
    moreWrap.classList.add('loaded');
    moreWrap.removeAttribute('aria-hidden');
    btn.style.display = 'none';
  });
})();
</script>
