  { name:'Simone Neri',            logo:'https://mclair.com.br/images/galeria/25-01-2021_1_1dfec622f48b7e6dd09af51b5c3dc7f9.png' },
  { name:'Trinta e Três Tattoo',   logo:'https://mclair.com.br/images/galeria/24-02-2020_1_5f223f44b3a29468b434011fddd554e4.jpg' },
  { name:'Vissla Aut',             logo:'https://mclair.com.br/images/galeria/25-01-2021_1_f74f3bcbdf8a02edb1d6604db961ddfd.png' },
  { name:'YNus Itá Digital',       logo:'https://mclair.com.br/images/galeria/26-01-2021_1_11535f163d849f16b286848b80e65d6e.png' },
  { name:'',                       logo:'https://mclair.com.br/images/galeria/24-02-2020_1_15688bd282380991aaf32679a8aadec9.jpg' },
];

const stats = [
  { n: '200+', label: 'Clientes atendidos' },
  { n: '8+', label: 'Anos de mercado' },
  { n: '23+', label: 'Segmentos' },
];
---

<Layout
  title="Clientes — Mclair Agência de Marketing"
  description="Conheça os clientes e empresas que confiam na Mclair para suas estratégias de Comunicação, Marketing de Autoridade e Assessoria de Imprensa."
>

<!-- HERO -->
<section class="clients-hero">
  <div class="ch-photo-bg" aria-hidden="true">
    <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1600&q=80&auto=format&fit=crop" alt="" class="ch-photo-img" />
    <div class="ch-photo-overlay"></div>
  </div>
  <div class="ch-bg" aria-hidden="true">
    <div class="ch-blob ch-blob-1"></div>
    <div class="ch-blob ch-blob-2"></div>
    <div class="ch-grid"></div>
  </div>
  <div class="container ch-inner">
    <div class="ch-content">
      <p class="eyebrow eyebrow-light" data-anim style="justify-content:flex-start">
        <span class="he-line"></span>
        Empresas que confiam na Mclair
      </p>
      <h1 class="ch-title" data-anim data-delay="1">
        Nossos<br/><em>Clientes</em>
      </h1>
      <p class="ch-lead" data-anim data-delay="2">
        Mais de 200 empresas e profissionais já transformaram sua comunicação com a Mclair. Marcas que lideram seus mercados e autoridades que são referência.
      </p>
    </div>
    <div class="ch-stats" data-anim="right" data-delay="2">
      {stats.map(s => (
        <div class="chs-item">
          <strong class="chs-num">{s.n}</strong>
          <span class="chs-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- LOGOS GRID -->
<section class="section logos-section">
  <div class="container">
    <div style="text-align:center;max-width:560px;margin:0 auto 64px">
      <p class="eyebrow" data-anim style="justify-content:center">Portfólio de clientes</p>
      <h2 class="section-title" data-anim data-delay="1" style="margin-top:14px">
        Marcas que <span>acreditam</span> na nossa abordagem
      </h2>
    </div>

    <div class="logos-grid stagger-children">
      {clients.map((c, i) => (
        <div class="logo-card" data-anim data-delay={((i % 4) + 1).toString()}>
          <img src={c.logo} alt={c.name || 'Cliente Mclair'} loading="lazy" class="logo-img"
            onerror="this.style.opacity='0';this.style.pointerEvents='none'" />
          <span class="logo-name">{c.name || ''}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA STRIP -->
<section class="cta-strip">
  <div class="container cta-inner">
    <div>
      <h2 class="cta-title">Sua marca pode ser a próxima.</h2>
      <p class="cta-sub">Transformamos comunicação em autoridade e autoridade em resultados reais.</p>
    </div>
    <div class="cta-actions">
      <a href="/contato" class="btn-primary">
        Falar com a Mclair
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/cases" class="btn-outline">Ver nossos cases</a>
    </div>
  </div>
</section>

</Layout>

<style>
/* ═══ HERO ═══ */
.clients-hero {
  min-height: 60vh;
  background: var(--dark);
  position: relative; overflow: hidden;
  display: flex; align-items: center;
  padding-top: 88px;
}
.ch-photo-bg { position:absolute; inset:0; z-index:0; }
.ch-photo-img { width:100%; height:100%; object-fit:cover; object-position:center 40%; }
.ch-photo-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(21,18,16,.9) 0%,rgba(21,18,16,.7) 100%); }
.ch-bg { position:absolute;inset:0;pointer-events:none; z-index:1; }
.ch-blob {
  position:absolute;border-radius:50%;filter:blur(80px);
  animation:blob-float 10s ease-in-out infinite;
}
.ch-blob-1 { width:500px;height:500px;top:-120px;right:-80px;background:radial-gradient(circle,rgba(200,16,46,.12) 0%,transparent 70%); }
.ch-blob-2 { width:300px;height:300px;bottom:-60px;left:0;background:radial-gradient(circle,rgba(27,138,118,.08) 0%,transparent 70%);animation-delay:-5s; }
.ch-grid {
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(200,16,46,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(200,16,46,.05) 1px,transparent 1px);
  background-size:64px 64px;
}
@keyframes blob-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-24px)} }

.ch-inner {
  position:relative; z-index:2;
  display:grid;grid-template-columns:1fr auto;
  align-items:center;gap:60px;
  padding-top:80px;padding-bottom:80px;
}
.eyebrow-light { color:rgba(255,255,255,.45) !important; }
.eyebrow-light .he-line { background:rgba(255,255,255,.2) !important; }
.he-line { display:inline-block;width:32px;height:2px;background:var(--red);flex-shrink:0; }

.ch-title {
  font-size:clamp(3rem,6vw,6rem);font-weight:900;line-height:1.02;
  letter-spacing:-.04em;color:#fff;margin-top:16px;margin-bottom:20px;
}
.ch-title em { color:var(--red);font-style:normal; }
.ch-lead { font-size:1rem;color:rgba(255,255,255,.5);line-height:1.8;max-width:460px;font-weight:300; }

.ch-stats {
  display:flex;flex-direction:column;gap:0;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);
  border-radius:var(--r-xl);padding:32px 36px;min-width:220px;
}
.chs-item {
  display:flex;flex-direction:column;gap:4px;
  padding:16px 0;border-bottom:1px solid rgba(255,255,255,.08);
}
.chs-item:last-child { border:none; }
.chs-num { font-size:2.4rem;font-weight:900;color:#fff;line-height:1; }
.chs-label { font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.35); }

/* ═══ LOGOS GRID ═══ */
.logos-section { background:#fff; }

.logos-grid {
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:0;
}
.logo-card {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:32px 20px; background:transparent;
  border-bottom:1px solid var(--line); border-right:1px solid var(--line);
  min-height:130px; position:relative;
  transition:background .25s, transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s, z-index 0s;
}
.logo-card:nth-child(5n) { border-right:none; }
.logo-card:hover {
  background:var(--cream);
  transform:scale(1.12);
  box-shadow:0 12px 40px rgba(0,0,0,.1);
  z-index:2; border-color:transparent;
  border-radius:var(--r-md);
}
.logo-img {
  max-width:130px; max-height:60px;
  width:auto; height:auto; object-fit:contain;
  filter:grayscale(100%); opacity:.45;
  transition:filter .3s, opacity .3s, transform .3s cubic-bezier(.22,1,.36,1);
  display:block;
}
.logo-card:hover .logo-img {
  filter:grayscale(0%); opacity:1;
  transform:scale(1.06);
}
.logo-name {
  display:block; margin-top:10px;
  font-size:.58rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  color:var(--ink-3); text-align:center;
  opacity:0; transform:translateY(4px);
  transition:opacity .25s, transform .25s;
  min-height:1em;
}
.logo-card:hover .logo-name { opacity:1; transform:translateY(0); }

/* ═══ CTA STRIP ═══ */
.cta-strip {
  background:var(--dark);
  padding:80px 0;
}
.cta-inner {
  display:flex;align-items:center;justify-content:space-between;gap:40px;flex-wrap:wrap;
}
.cta-title { font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:#fff;letter-spacing:-.02em; }
.cta-sub { font-size:.95rem;color:rgba(255,255,255,.45);font-weight:300;margin-top:8px; }
.cta-actions { display:flex;gap:12px;align-items:center;flex-shrink:0; }
.btn-outline {
  display:inline-flex;align-items:center;
  font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(255,255,255,.7);border:1.5px solid rgba(255,255,255,.2);
  padding:.9rem 1.8rem;border-radius:var(--r-sm);
  transition:border-color .2s,color .2s;
  white-space:nowrap;
}
.btn-outline:hover { border-color:rgba(255,255,255,.6);color:#fff; }

/* ═══ RESPONSIVE ═══ */
@media (max-width:900px) {
  .ch-inner { grid-template-columns:1fr; }
  .ch-stats { flex-direction:row;flex-wrap:wrap;width:100%;padding:20px; }
  .chs-item { border-bottom:none;border-right:1px solid rgba(255,255,255,.08);padding:0 20px; }
  .chs-item:last-child { border:none; }
  .logos-grid { grid-template-columns:repeat(4,1fr); }
  .logo-card:nth-child(5n) { border-right:1px solid var(--line); }
  .logo-card:nth-child(4n) { border-right:none; }
}
@media (max-width:640px) {
  .cta-inner { flex-direction:column;align-items:flex-start; }
  .logos-grid { grid-template-columns:repeat(3,1fr); }
  .logo-card:nth-child(4n) { border-right:1px solid var(--line); }
  .logo-card:nth-child(3n) { border-right:none; }
  .ch-stats { gap:0; }
}
</style>
