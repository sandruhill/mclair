---
const WA = 'https://wa.me/5511988600372?text=Olá%20Mclair!';
const nav = [
  { label: 'Início',    href: '/' },
  { label: 'Sobre',     href: '/sobre' },
  { label: 'Serviços',  href: '/servicos' },
  { label: 'Mentorias', href: '/mentorias' },
  { label: 'Cases',     href: '/cases' },
  { label: 'Contato',   href: '/contato' },
];
const servicos = [
  'Marketing de Autoridade',
  'Assessoria de Imprensa',
  'Branding Estratégico',
  'Marketing Digital',
  'Consultoria em Comunicação',
  'Mentoria Bolder',
  'Mentoria Bolder Press',
];
---

<footer id="site-footer">
  <!-- CTA band -->
  <div class="ft-band">
    <div class="container ft-band-inner">
      <div class="ft-band-text" data-anim>
        <span class="ft-band-eyebrow">Pronto para começar?</span>
        <h2 class="ft-band-title">Transforme sua comunicação em legado.</h2>
      </div>
      <div class="ft-band-actions" data-anim data-delay="2">
        <a href={WA} class="btn-primary" target="_blank" rel="noopener">
          Falar com Especialista
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/contato" class="btn-outline" style="color:#fff;border-color:rgba(255,255,255,.3)">
          Enviar Mensagem
        </a>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="ft-main">
    <div class="container ft-grid">
      <div class="ft-brand">
        <a href="/" class="ft-logo-link">
          <img src="/logos/logo-negativo.png" alt="Mclair" height="32" />
        </a>
        <p class="ft-tagline">
          Comunicação Estratégica que posiciona sua marca como referência. Marketing de Autoridade que constrói legados duradouros.
        </p>
        <div class="ft-socials">
          <a href="https://instagram.com/mclair.com.br" target="_blank" rel="noopener" aria-label="Instagram" class="ft-soc">
            <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://linkedin.com/company/mclair-comunicacao" target="_blank" rel="noopener" aria-label="LinkedIn" class="ft-soc">
            <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={WA} target="_blank" rel="noopener" aria-label="WhatsApp" class="ft-soc ft-soc-green">
            <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <div class="ft-col">
        <p class="ft-col-h">Navegação</p>
        <ul>{nav.map(n => <li><a href={n.href}>{n.label}</a></li>)}</ul>
      </div>

      <div class="ft-col">
        <p class="ft-col-h">Serviços</p>
        <ul>{servicos.map(s => <li><span>{s}</span></li>)}</ul>
      </div>

      <div class="ft-col">
        <p class="ft-col-h">Contato</p>
        <ul class="ft-contact-list">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            <a href="mailto:kelly@mclair.com.br">kelly@mclair.com.br</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.63 19.79 19.79 0 01.07 2.18 2 2 0 012.06 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            <a href="tel:+5511988600372">(11) 98860-0372</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            São Paulo, SP — Brasil
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="ft-bottom">
    <div class="container ft-bottom-inner">
      <span>© 2025 Mclair Comunicação. Todos os direitos reservados.</span>
      <div class="ft-bottom-links">
        <a href="/contato">Política de Privacidade</a>
        <span>·</span>
        <a href="/contato">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>

<style>
  #site-footer { background: var(--dark); color: rgba(255,255,255,.5); font-size:.88rem; }

  /* CTA band */
  .ft-band { background: var(--red); padding: 72px 0; }
  .ft-band-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 40px; flex-wrap: wrap;
  }
  .ft-band-eyebrow {
    font-size:.65rem; font-weight:700; letter-spacing:.22em; text-transform:uppercase;
    color:rgba(255,255,255,.7); display:block; margin-bottom:10px;
  }
  .ft-band-title {
    font-size: clamp(1.6rem,3.5vw,2.8rem); font-weight:900;
    color:#fff; line-height:1.1; letter-spacing:-.02em;
  }
  .ft-band-actions { display:flex; gap:12px; flex-wrap:wrap; flex-shrink:0; }
  .ft-band-actions .btn-primary { background:#fff; color:var(--red); }
  .ft-band-actions .btn-primary:hover { background:rgba(255,255,255,.9); box-shadow:none; }
  .ft-band-actions .btn-outline { color:#fff; border-color:rgba(255,255,255,.35); }
  .ft-band-actions .btn-outline:hover { border-color:#fff; color:#fff; background:rgba(255,255,255,.1); }

  /* Main grid */
  .ft-main { padding: 72px 0 56px; border-bottom: 1px solid rgba(255,255,255,.06); }
  .ft-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: 48px 40px;
    align-items: start;
  }

  .ft-logo-link { display:inline-block; margin-bottom:18px; }
  .ft-logo-link img { height:30px; width:auto; opacity:.85; }
  .ft-tagline {
    font-size:.85rem; font-weight:300; color:rgba(255,255,255,.35);
    line-height:1.75; max-width:280px; margin-bottom:24px;
  }
  .ft-socials { display:flex; gap:8px; }
  .ft-soc {
    width:34px; height:34px; border-radius:var(--r-sm);
    display:flex; align-items:center; justify-content:center;
    color:rgba(255,255,255,.3); border:1px solid rgba(255,255,255,.1);
    transition:color .2s, border-color .2s, background .2s;
  }
  .ft-soc:hover { color:var(--red); border-color:rgba(200,16,46,.4); background:rgba(200,16,46,.08); }
  .ft-soc-green:hover { color:#25d366; border-color:rgba(37,211,102,.3); background:rgba(37,211,102,.06); }

  .ft-col-h {
    font-size:.58rem; letter-spacing:.22em; text-transform:uppercase;
    color:rgba(255,255,255,.25); font-weight:700; margin-bottom:18px;
  }
  .ft-col ul { display:flex; flex-direction:column; gap:10px; }
  .ft-col li { font-size:.85rem; color:rgba(255,255,255,.38); }
  .ft-col li a { transition:color .2s; }
  .ft-col li a:hover { color:rgba(255,255,255,.8); }
  .ft-col li span { color:rgba(255,255,255,.3); }

  .ft-contact-list li {
    display:flex; align-items:flex-start; gap:10px; color:rgba(255,255,255,.3);
  }
  .ft-contact-list svg { color:var(--red); flex-shrink:0; margin-top:2px; }
  .ft-contact-list a { color:rgba(255,255,255,.38); transition:color .2s; }
  .ft-contact-list a:hover { color:rgba(255,255,255,.8); }

  /* Bottom */
  .ft-bottom { padding:20px 0; }
  .ft-bottom-inner {
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:8px;
    font-size:.7rem; color:rgba(255,255,255,.18);
  }
  .ft-bottom-links { display:flex; gap:8px; align-items:center; }
  .ft-bottom-links a { transition:color .2s; }
  .ft-bottom-links a:hover { color:rgba(255,255,255,.5); }

  @media (max-width:1024px) { .ft-grid { grid-template-columns:1fr 1fr; } .ft-brand { grid-column:1/-1; } }
  @media (max-width:600px) {
    .ft-grid { grid-template-columns:1fr; }
    .ft-band-inner, .ft-bottom-inner { flex-direction:column; text-align:center; }
    .ft-band-actions { justify-content:center; }
    .ft-socials { justify-content:center; }
  }
</style>
