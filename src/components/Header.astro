---
const caseLinks = [
  { label:'Claudia Elisa',       href:'/cases/claudia-elisa',    tag:'Marca Pessoal',          img:'/cases-img/claudia-elisa-marca-pessoal-lideranca.jpg' },
  { label:'Fidalgo Leilões',     href:'/cases/fidalgo',          tag:'Assessoria de Imprensa', img:'/cases-img/fidalgo-leiloes-assessoria-imprensa.jpg' },
  { label:'Alexandre Magno',     href:'/cases/alexandre-magno',  tag:'Gestão de Crise',        img:'/cases-img/alexandre-magno-gestao-crise-pr.jpg' },
  { label:'Elemar Jr. / EximiaCo', href:'/cases/elemar-jr',      tag:'Branding',               img:'/cases-img/elemar-jr-branding-tecnologia-software.jpg' },
  { label:'BMS / ABIMAQ',        href:'/cases/bms-abimaq',       tag:'Internacional',           img:'/cases-img/bms-abimaq-maquinario-industrial-exportacao.jpg' },
  { label:'Insight RH',          href:'/cases/insight-rh',       tag:'Rebranding & Naming',    img:'/cases-img/insight-rh-lideranca-gestao-pessoas.jpg' },
  { label:'Diego Nogare',        href:'/cases/diego-nogare',     tag:'Dados & IA',             img:'/cases-img/diego-nogare-inteligencia-artificial-dados.jpg' },
  { label:'Lambda3',             href:'/cases/lambda3',          tag:'Assessoria de Imprensa', img:'/cases-img/lambda3-tecnologia-dados-comunicacao.jpg' },
  { label:'Zbra',                href:'/cases/zbra',             tag:'Rebranding',             img:'/cases-img/zbra-rebranding-digital-tecnologia.jpg' },
  { label:'Guiando / NexInvoice',href:'/cases/nexinvoice',       tag:'Naming & Branding',      img:'/cases-img/nexinvoice-fintech-branding-naming.jpg' },
  { label:'Silene Chiconini',    href:'/cases/silene-chiconini', tag:'Marca Pessoal',          img:'/cases-img/silene-chiconini-consultoria-sustentabilidade.jpg' },
];

const svcLinks = [
  { label:'Marketing de Autoridade', href:'/servicos/marketing-de-autoridade' },
  { label:'Assessoria de Imprensa', href:'/servicos/assessoria-de-imprensa' },
  { label:'Branding Estratégico', href:'/servicos/branding-estrategico' },
  { label:'Marketing Digital Integrado', href:'/servicos/marketing-digital' },
  { label:'Consultoria em Comunicação', href:'/servicos/consultoria-em-comunicacao' },
  { label:'Mentorias Exclusivas', href:'/servicos/mentorias-exclusivas' },
];

const WA = 'https://wa.me/5511988600372?text=Olá%20Mclair!%20Gostaria%20de%20conhecer%20os%20serviços.';
---

<header id="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="Mclair home">
      <img src="/logos/logo-color.png" alt="Mclair" class="logo-default" />
      <img src="/logos/logo-white-hd.png" alt="Mclair" class="logo-white" />
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <a href="/" class="nav-link">Início</a>
      <a href="/sobre" class="nav-link">Sobre</a>

      <!-- Serviços dropdown -->
      <div class="nav-drop-wrap">
        <a href="/servicos" class="nav-link nav-parent">
          Serviços
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <div class="nav-dropdown">
          {svcLinks.map(s => (
            <a href={s.href} class="nd-item">{s.label}</a>
          ))}
        </div>
      </div>

      <!-- Cases mega menu -->
      <div class="nav-drop-wrap" id="cases-drop-wrap">
        <a href="/cases" class="nav-link nav-parent">
          Cases
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <div class="nav-dropdown nd-cases" id="cases-mega">
          <!-- Preview image panel -->
          <div class="nd-preview" aria-hidden="true">
            <img id="case-preview-img" src={caseLinks[0].img} alt="" class="nd-preview-img" loading="eager" />
            <div class="nd-preview-overlay">
              <span class="nd-preview-tag">Case</span>
              <strong id="case-preview-name">{caseLinks[0].label}</strong>
            </div>
          </div>
          <!-- Links list -->
          <div class="nd-cases-list">
            <div class="nd-cases-grid">
              {caseLinks.map((c, i) => (
                <a
                  href={c.href}
                  class={`nd-item nd-case-item${i === 0 ? ' nd-case-active' : ''}`}
                  data-img={c.img}
                  data-name={c.label}
                >
                  <span class="nd-name">{c.label}</span>
                  <span class="nd-tag">{c.tag}</span>
                </a>
              ))}
            </div>
            <a href="/cases" class="nd-all-cases">
              Ver todos os cases
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <a href="/clientes" class="nav-link">Clientes</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/mentorias" class="nav-link">Mentorias</a>
      <a href="/contato" class="nav-link">Contato</a>
    </nav>

    <div class="header-cta-wrap">
      <a href={WA} class="header-cta" target="_blank" rel="noopener">
        <svg class="wa-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9z"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>
        Fale Conosco
      </a>
      <button class="burger" id="burger" aria-label="Abrir menu" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div id="mobile-nav" class="mobile-nav" role="dialog" aria-modal="true" aria-label="Menu">
  <div class="mobile-overlay" id="mobile-overlay"></div>
  <div class="mobile-drawer">
    <div class="drawer-header">
      <img src="/logos/logo-icone-M.png" alt="Mclair" width="120" height="120" style="object-fit:contain" />
      <button class="drawer-close" id="drawer-close" aria-label="Fechar menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="drawer-nav">
      <a href="/" class="drawer-link" style="--i:0"><span class="dl-num">01</span>Início</a>
      <a href="/sobre" class="drawer-link" style="--i:1"><span class="dl-num">02</span>Sobre</a>
      <div class="drawer-group" style="--i:2">
        <a href="/servicos" class="drawer-link"><span class="dl-num">03</span>Serviços</a>
        <div class="drawer-sub">
          {svcLinks.map(s => <a href={s.href} class="drawer-sub-link">{s.label}</a>)}
        </div>
      </div>
      <div class="drawer-group" style="--i:3">
        <a href="/cases" class="drawer-link"><span class="dl-num">04</span>Cases</a>
        <div class="drawer-sub">
          {caseLinks.map(c => <a href={c.href} class="drawer-sub-link">{c.label}</a>)}
        </div>
      </div>
      <a href="/clientes" class="drawer-link" style="--i:4"><span class="dl-num">05</span>Clientes</a>
      <a href="/blog" class="drawer-link" style="--i:5"><span class="dl-num">06</span>Blog</a>
      <a href="/mentorias" class="drawer-link" style="--i:6"><span class="dl-num">07</span>Mentorias</a>
      <a href="/contato" class="drawer-link" style="--i:7"><span class="dl-num">08</span>Contato</a>
    </nav>
    <div class="drawer-footer">
      <a href={WA} class="btn-primary" target="_blank" rel="noopener">
        Falar no WhatsApp
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <div class="drawer-contact">
        <span>kelly@mclair.com.br</span>
        <span>(11) 98860-0372</span>
      </div>
    </div>
  </div>
</div>

<style>
  #site-header {
    position: fixed; top:0; left:0; right:0; z-index:500;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background .4s ease, border-color .4s ease, box-shadow .4s ease;
  }
  #site-header.scrolled {
    background: linear-gradient(to bottom, rgba(250,250,248,0.94) 0%, rgba(250,250,248,0.7) 60%, transparent 100%);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-color: transparent;
    box-shadow: none;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    height: 88px;
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: clamp(20px,5vw,64px);
    transition: height .3s;
  }
  #site-header.scrolled .header-inner { height: 72px; }

  .logo-link { display: flex; align-items: center; text-decoration: none; transition: opacity .2s; }
  .logo-link:hover { opacity: .85; }
  .logo-default { height: 48px; width: auto; object-fit: contain; display: none; }
  .logo-white   { height: 48px; width: auto; object-fit: contain; display: block; }
  #site-header.scrolled .logo-default { display: block; }
  #site-header.scrolled .logo-white   { display: none; }

  .nav { display: flex; align-items: center; justify-content: center; gap: 0; }
  .nav-link {
    display: flex; align-items: center; gap: 4px;
    font-size: .73rem; font-weight: 400;
    letter-spacing: .07em; text-transform: uppercase;
    color: rgba(255,255,255,.75);
    padding: .5rem .85rem;
    position: relative;
    transition: color .3s;
    white-space: nowrap;
  }
  #site-header.scrolled .nav-link { color: var(--ink-2); }
  .nav-link::after {
    content: ''; position:absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 0; height: 2px;
    background: var(--red);
    transition: width .25s cubic-bezier(.22,1,.36,1);
    border-radius: 99px;
  }
  .nav-link:hover { color: rgba(255,255,255,1); }
  #site-header.scrolled .nav-link:hover { color: var(--red); }
  .nav-link:hover::after { width: 70%; }
  .nav-parent svg { opacity: .4; transition: transform .2s; }
  .nav-drop-wrap:hover .nav-parent svg { transform: rotate(180deg); }

  /* DROPDOWN BASE */
  .nav-drop-wrap { position: relative; }
  .nav-drop-wrap::after {
    content: ''; position: absolute;
    bottom: -12px; left: 0; right: 0; height: 12px;
    background: transparent;
  }
  .nav-dropdown {
    position: absolute; top: calc(100% + 8px); left: 50%;
    transform: translateX(-50%) translateY(6px);
    background: #fff; border: 1px solid var(--line);
    border-radius: var(--r-lg); box-shadow: var(--shadow-lg);
    min-width: 220px; padding: 8px;
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .22s ease, transform .22s ease, visibility .22s;
    z-index: 200;
  }
  .nav-drop-wrap:hover .nav-dropdown {
    opacity: 1; visibility: visible; pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nd-item {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding: 9px 12px; border-radius: var(--r-md);
    font-size: .82rem; font-weight: 500; color: var(--ink-2);
    transition: background .15s, color .15s;
    text-decoration: none;
    white-space: nowrap;
  }
  .nd-item:hover { background: var(--cream); color: var(--red); }
  .nd-tag {
    font-size: .58rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-4); background: var(--cream-2);
    padding: .18rem .5rem; border-radius: 99px;
    white-space: nowrap; flex-shrink: 0;
  }
  .nd-item:hover .nd-tag { background: var(--red-soft); color: var(--red); }

  /* ── CASES MEGA MENU ── */
  .nd-cases {
    display: flex;
    min-width: 640px;
    padding: 0;
    overflow: hidden;
    left: 50%;
    transform: translateX(-50%) translateY(6px);
  }
  .nav-drop-wrap:hover .nd-cases {
    transform: translateX(-50%) translateY(0);
  }

  /* Preview image panel */
  .nd-preview {
    width: 220px;
    min-height: 240px;
    flex-shrink: 0;
    align-self: stretch;
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg) 0 0 var(--r-lg);
    background: var(--dark);
  }
  .nd-preview-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: opacity .12s ease;
  }
  .nd-preview-img.fading { opacity: 0; }
  .nd-preview-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(15,12,10,.85) 0%, transparent 100%);
    padding: 20px 16px 16px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .nd-preview-tag {
    font-size: .55rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
    color: var(--red); display: block;
  }
  #case-preview-name {
    font-size: .88rem; font-weight: 700; color: #fff; line-height: 1.2;
  }

  /* Links list */
  .nd-cases-list {
    flex: 1;
    padding: 8px;
    display: flex; flex-direction: column;
  }
  .nd-cases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 4px;
  }
  .nd-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .nd-case-item.nd-case-active {
    background: var(--cream);
    color: var(--red);
  }
  .nd-case-item.nd-case-active .nd-tag {
    background: var(--red-soft); color: var(--red);
  }

  .nd-all-cases {
    display: flex; align-items: center; gap: 6px; justify-content: center;
    margin-top: 4px; padding: 8px 12px;
    font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--red); border-top: 1px solid var(--line);
    text-decoration: none;
    transition: gap .2s;
  }
  .nd-all-cases:hover { gap: 10px; }

  /* ── HEADER CTA ── */
  .header-cta-wrap { display: flex; align-items: center; gap: 12px; }
  .header-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .72rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    color: #fff; background: var(--red);
    padding: .65rem 1.4rem; border-radius: var(--r-sm);
    white-space: nowrap;
    transition: background .2s, transform .15s, box-shadow .2s;
    box-shadow: 0 2px 12px rgba(200,16,46,.3);
  }
  .header-cta:hover { background: var(--red-2); transform: translateY(-1px); box-shadow: 0 4px 20px rgba(200,16,46,.4); }
  .header-cta { overflow: visible; }
  .wa-icon { flex-shrink: 0; transition: transform .4s cubic-bezier(.34,1.56,.64,1); }
  .header-cta:hover .wa-icon { transform: scale(1.6) rotate(18deg); }
  .burger {
    display: none;
    flex-direction: column; justify-content: center; align-items: center; gap: 6px;
    width: 40px; height: 40px;
    background: transparent; border: 1.5px solid rgba(255,255,255,.35);
    border-radius: var(--r-sm);
    transition: border-color .3s;
  }
  #site-header.scrolled .burger { border-color: var(--line-2); }
  .burger span {
    display: block; width: 18px; height: 1.5px;
    background: #fff; border-radius: 99px;
    transition: all .3s, background .3s;
  }
  #site-header.scrolled .burger span { background: var(--ink); }
  .burger[aria-expanded="true"] span:nth-child(1) { transform: rotate(45deg) translate(3.5px,5px); background:var(--red); }
  .burger[aria-expanded="true"] span:nth-child(2) { transform: rotate(-45deg) translate(3.5px,-5px); background:var(--red); }

  /* MOBILE NAV */
  .mobile-nav { position: fixed; inset: 0; z-index: 999; visibility: hidden; pointer-events: none; }
  .mobile-nav.open { visibility: visible; pointer-events: auto; }
  .mobile-overlay { position: absolute; inset: 0; background: rgba(28,26,23,0); transition: background .4s; }
  .mobile-nav.open .mobile-overlay { background: rgba(28,26,23,.5); }
  .mobile-drawer {
    position: absolute; top:0; right:0; bottom:0;
    width: min(400px, 92vw);
    background: var(--cream); display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform .4s cubic-bezier(.22,1,.36,1);
    box-shadow: -20px 0 60px rgba(0,0,0,.12);
    overflow-y: auto;
  }
  .mobile-nav.open .mobile-drawer { transform: none; }
  .drawer-header { display: flex; align-items: center; justify-content: space-between; padding: 24px 28px; border-bottom: 1px solid var(--line); }
  .drawer-close { width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--ink-3);transition:color .2s; }
  .drawer-close:hover { color:var(--red); }
  .drawer-nav { flex:1;padding:28px;display:flex;flex-direction:column;gap:4px; }
  .drawer-link {
    display:flex;align-items:center;gap:14px;padding:14px 0;
    border-bottom:1px solid var(--line);
    font-size:1.1rem;font-weight:700;color:var(--ink);
    opacity:0;transform:translateX(20px);
    transition:color .2s,opacity .3s,transform .3s;
    transition-delay:calc(var(--i,0)*50ms+100ms);
    text-decoration:none;
  }
  .mobile-nav.open .drawer-link { opacity:1;transform:none; }
  .drawer-link:hover { color:var(--red); }
  .dl-num { font-size:.6rem;letter-spacing:.2em;color:var(--red);width:20px;flex-shrink:0; }
  .drawer-group .drawer-link { border-bottom:none;padding-bottom:8px; }
  .drawer-sub { display:flex;flex-direction:column;gap:0;border-bottom:1px solid var(--line);padding-bottom:12px;padding-left:34px; }
  .drawer-sub-link { font-size:.82rem;color:var(--ink-3);padding:6px 0;transition:color .15s;text-decoration:none; }
  .drawer-sub-link:hover { color:var(--red); }
  .drawer-footer { padding:24px 28px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:16px; }
  .drawer-footer .btn-primary { justify-content:center; }
  .drawer-contact { display:flex;flex-direction:column;gap:4px; }
  .drawer-contact span { font-size:.82rem;color:var(--ink-3); }

  @media (max-width: 1040px) {
    .nav { display: none; }
    .header-cta { display: none; }
    .burger { display: flex; }
    .header-inner { grid-template-columns: auto 1fr; }
    .header-cta-wrap { justify-self: end; }
  }
</style>

<script is:inline>
(function() {
  var hdr = document.getElementById('site-header');
  var burger = document.getElementById('burger');
  var mNav = document.getElementById('mobile-nav');
  var overlay = document.getElementById('mobile-overlay');
  var closeBtn = document.getElementById('drawer-close');
  if (!hdr || !burger || !mNav) return;

  window.addEventListener('scroll', function() {
    hdr.classList.toggle('scrolled', window.scrollY > 30);
  }, { passive: true });

  function openMenu() { mNav.classList.add('open'); burger.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; }
  function closeMenu() { mNav.classList.remove('open'); burger.setAttribute('aria-expanded','false'); document.body.style.overflow=''; }
  burger.addEventListener('click', function() { mNav.classList.contains('open') ? closeMenu() : openMenu(); });
  if (overlay) overlay.addEventListener('click', closeMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  mNav.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });

  // Cases mega menu — image preview on hover
  var previewImg  = document.getElementById('case-preview-img');
  var previewName = document.getElementById('case-preview-name');
  var caseItems   = document.querySelectorAll('.nd-case-item');
  var fadeTimer;

  caseItems.forEach(function(item) {
    item.addEventListener('mouseenter', function() {
      var newImg  = item.dataset.img;
      var newName = item.dataset.name;

      // Active state
      caseItems.forEach(function(el) { el.classList.remove('nd-case-active'); });
      item.classList.add('nd-case-active');

      // Cross-fade image — pula se já é a mesma imagem
      if (previewImg.getAttribute('src') === newImg) return;
      clearTimeout(fadeTimer);
      previewImg.classList.add('fading');
      fadeTimer = setTimeout(function() {
        previewImg.src = newImg;
        previewName.textContent = newName;
        previewImg.classList.remove('fading');
      }, 60);
    });
  });
})();
</script>
